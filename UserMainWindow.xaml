                                              SelectedIndex="0">
                                        <ComboBoxItem x:Name="SortPopularItem" Tag="popular"    Content="Сначала новые"/>
                                        <ComboBoxItem x:Name="SortPriceAscItem" Tag="price_asc"  Content="Цена: сначала дешевле"/>
                                        <ComboBoxItem x:Name="SortPriceDescItem" Tag="price_desc" Content="Цена: сначала дороже"/>
                                        <ComboBoxItem x:Name="SortTitleItem" Tag="title"      Content="По названию"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- Product grid -->
                            <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding PrimaryVisibleProducts}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="4"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <StaticResource ResourceKey="StoreProductCardTemplate"/>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty state -->
                            <Border Margin="0,4,0,0" Padding="28"
                                    Background="White" BorderThickness="0" CornerRadius="18"
                                    Effect="{StaticResource StoreCardShadow}"
                                    Visibility="{Binding EmptyStateVisibility}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="EmptyCatalogTitleTextBlock" FontSize="18" FontWeight="Black"
                                               Foreground="{StaticResource StoreTextBrush}"
                                               HorizontalAlignment="Center"
                                               Text="Ничего не найдено"/>
                                    <TextBlock Margin="0,8,0,0" FontSize="13"
                                               Foreground="{StaticResource StoreMutedBrush}"
                                               HorizontalAlignment="Center"
                                               Text="{Binding CatalogStatusText}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- ══════  RIGHT SIDEBAR – flat, no card borders  ══════ -->
                    <StackPanel Grid.Row="0" Grid.Column="1">

                        <!-- CATEGORIES -->
                        <TextBlock x:Name="CategoriesTitleTextBlock" FontSize="15" FontWeight="Black"
                                   Foreground="{StaticResource StoreTextBrush}"
                                   Text="Категории"/>
                        <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource CategoryRowButtonStyle}"
                                            Click="CategoryFilterButton_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="26" Height="26"
                                                    Background="{StaticResource StoreAccentSoftBrush}"
                                                    BorderThickness="0" CornerRadius="13">
                                                <svg:SvgViewbox Width="14" Height="14"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Source="{Binding IconSource}"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Margin="10,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource StoreTextBrush}"
                                                       Text="{Binding CategoryName}"/>
                                            <TextBlock Grid.Column="2"
                                                       VerticalAlignment="Center" FontSize="12"
                                                       Foreground="{StaticResource StoreMutedBrush}"
                                                       Text="{Binding ProductCount}"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- QUICK FILTERS -->
                        <TextBlock x:Name="QuickFiltersTitleTextBlock" Margin="0,22,0,0"
                                   FontSize="15" FontWeight="Black"
                                   Foreground="{StaticResource StoreTextBrush}"
                                   Text="Быстрые фильтры"/>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <CheckBox x:Name="PhotoFilterCheckBox" Content="С фото" FontSize="13"
                                      VerticalContentAlignment="Center"
                                      Checked="QuickFilterChanged" Unchecked="QuickFilterChanged"/>
                            <CheckBox x:Name="HitsFilterCheckBox" Grid.Column="1" Content="Хиты" FontSize="13"
                                      VerticalContentAlignment="Center"
                                      Checked="QuickFilterChanged" Unchecked="QuickFilterChanged"/>
                            <CheckBox x:Name="Under100FilterCheckBox" Grid.Row="1" Margin="0,10,0,0"
                                      Content="До 100 MDL" FontSize="13"
                                      VerticalContentAlignment="Center"
                                      Checked="QuickFilterChanged" Unchecked="QuickFilterChanged"/>
                            <CheckBox x:Name="MuslinFilterCheckBox" Grid.Row="1" Grid.Column="1" Margin="0,10,0,0"
                                      Content="Муслин" FontSize="13"
                                      VerticalContentAlignment="Center"
                                      Checked="QuickFilterChanged" Unchecked="QuickFilterChanged"/>
                        </Grid>

                        <!-- PRICE -->
                        <TextBlock x:Name="PriceLabelTextBlock" Margin="0,18,0,0"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource StoreTextBrush}"
                                   Text="Цена"/>
                        <Canvas x:Name="PriceRangeCanvas"
                                Margin="0,10,0,0"
                                Height="28"
                                Background="Transparent"
                                Cursor="Hand"
                                MouseLeftButtonDown="PriceRangeCanvas_MouseLeftButtonDown"
                                MouseMove="PriceRangeCanvas_MouseMove"
                                MouseLeftButtonUp="PriceRangeCanvas_MouseLeftButtonUp"
                                SizeChanged="PriceRangeCanvas_SizeChanged">
                            <Border x:Name="PriceTrackBorder"
                                    Canvas.Top="11"
                                    Height="6"
                                    CornerRadius="3"
                                    Background="#FFF2D5E0"/>
                            <Border x:Name="PriceSelectedRangeBorder"
                                    Canvas.Top="11"
                                    Height="6"
                                    CornerRadius="3"
                                    Background="{StaticResource StoreAccentBrush}"/>
                            <Ellipse x:Name="MinPriceThumb"
                                     Canvas.Top="4"
                                     Width="20"
                                     Height="20"
                                     Fill="White"
                                     Stroke="{StaticResource StoreAccentBrush}"
                                     StrokeThickness="2.5"
                                     Cursor="Hand"
                                     MouseLeftButtonDown="PriceThumb_MouseLeftButtonDown"/>
                            <Ellipse x:Name="MaxPriceThumb"
                                     Canvas.Top="4"
                                     Width="20"
                                     Height="20"
                                     Fill="White"
                                     Stroke="{StaticResource StoreAccentDarkBrush}"
                                     StrokeThickness="2.5"
                                     Cursor="Hand"
                                     MouseLeftButtonDown="PriceThumb_MouseLeftButtonDown"/>
                        </Canvas>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="PriceFromTextBox"
                                     Padding="10,7" FontSize="12"
                                     TextChanged="PriceFilterTextChanged"
                                     VerticalContentAlignment="Center" Text=""/>
                            <TextBlock Grid.Column="1" Margin="8,0"
                                       VerticalAlignment="Center" FontSize="14"
                                       Foreground="{StaticResource StoreMutedBrush}" Text="—"/>
                            <TextBox x:Name="PriceToTextBox"
                                     Grid.Column="2"
                                     Padding="10,7" FontSize="12"
                                     TextChanged="PriceFilterTextChanged"
                                     VerticalContentAlignment="Center" Text=""/>
                        </Grid>

                        <!-- PROMO BANNER -->
                        <Border Margin="0,20,0,0"
                                Height="210"
                                Background="#FFFFFBFD"
                                BorderBrush="#FFF4C7D8"
                                BorderThickness="1.2"
                                CornerRadius="22"
                                Effect="{StaticResource StoreCardShadow}">
                            <Grid>
                                <Border Margin="5"
                                        Background="White"
                                        CornerRadius="18"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Image Source="{Binding PromoBannerImage}"
                                               Stretch="UniformToFill"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Offset="0" Color="#F2FFF8FB"/>
                                                    <GradientStop Offset="0.42" Color="#DBFFF9FC"/>
                                                    <GradientStop Offset="0.82" Color="#66FFFFFF"/>
                                                    <GradientStop Offset="1" Color="#08FFFFFF"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                    </Grid>
                                </Border>
                                <Rectangle Margin="5"
                                           Stroke="#18F26C98"
                                           StrokeThickness="1"
                                           RadiusX="18"
                                           RadiusY="18"/>
                                <StackPanel Margin="18,16,18,18"
                                            Width="164"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top">
                                    <Border HorizontalAlignment="Left"
                                            Padding="14,6"
                                            Background="#FFF35793"
                                            CornerRadius="16">
                                        <TextBlock x:Name="PromoTitleTextBlock"
                                                   FontSize="13"
                                                   FontWeight="Black"
                                                   Foreground="White"
                                                   Text="Муслин"/>
                                    </Border>
                                    <TextBlock x:Name="PromoDiscountTextBlock" Margin="0,16,0,0"
                                               FontSize="28" FontWeight="Black"
                                               LineHeight="30"
                                               Foreground="{StaticResource StoreAccentBrush}"
                                               Text="Нежный муслин"
                                               TextWrapping="Wrap"/>
                                    <TextBlock x:Name="PromoSubtitleTextBlock"
                                               FontSize="12.5" LineHeight="18"
                                               Foreground="{StaticResource StoreMutedBrush}"
                                               TextWrapping="Wrap"
                                               Text="Мягкие товары для малышей на каждый день" Height="49"/>
                                    <Button Margin="0,18,0,0"
                                            Width="176"
                                            Height="46"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Click="PromoButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="PromoButtonTextBlock"
                                                       Text="Смотреть товары"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Margin="8,0,0,0"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       VerticalAlignment="Center" Text="&#xE72A;"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <ItemsControl Grid.Row="1"
                                  Grid.ColumnSpan="2"
                                  Margin="0,18,0,0"
                                  ItemsSource="{Binding SecondaryVisibleProducts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="5"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <StaticResource ResourceKey="StoreProductCardTemplate"/>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- ══════════════  CART OVERLAY  ══════════════ -->
        <Grid Background="{StaticResource StoreOverlayBrush}"
              Visibility="{Binding CartOverlayVisibility}"
              d:Visibility="Collapsed"
              MouseDown="CartOverlay_MouseDown">
            <Border Width="392"
                    Margin="0,18,18,18"
                    HorizontalAlignment="Right"
                    Background="White"
                    BorderThickness="0"
                    CornerRadius="24"
                    Effect="{StaticResource StoreCardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="20,20,20,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="32" Height="32" CornerRadius="10"
                                        Background="#FFFFE5EF">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15"
                                               Foreground="{StaticResource StoreAccentBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Text="&#xE7BF;"/>
                                </Border>
                                <TextBlock x:Name="CartOverlayTitleTextBlock"
                                           Margin="10,0,0,0"
                                           FontSize="20" FontWeight="Black"
                                           Foreground="{StaticResource StoreTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="Корзина"/>
                                <Border Margin="10,0,0,0" Padding="8,3"
                                        CornerRadius="20" VerticalAlignment="Center"
                                        Visibility="{Binding CartBadgeVisibility}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Offset="0" Color="#FFEC5A8D"/>
                                            <GradientStop Offset="1" Color="#FFD83F77"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="White"
                                               Text="{Binding CartBadgeText}"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Margin="0,5,0,0" FontSize="12"
                                       Foreground="{StaticResource StoreMutedBrush}"
                                       Text="{Binding CartItemsCountText}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource IconButtonStyle}"
                                Click="CloseCartButton_Click">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{StaticResource StoreTextBrush}"
                                       Text="&#xE711;"/>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" Margin="14,0,14,0">
                        <Border Padding="16"
                                Background="{StaticResource StoreSurfaceAltBrush}"
                                BorderThickness="0" CornerRadius="16"
                                Visibility="{Binding CartEmptyVisibility}">
                            <StackPanel>
                                <Border Width="52" Height="52" CornerRadius="26"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Offset="0" Color="#FFFFE5EF"/>
                                            <GradientStop Offset="1" Color="#FFF0C8D8"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="22"
                                               Foreground="{StaticResource StoreAccentBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Text="&#xE7BF;"/>
                                </Border>
                                <TextBlock x:Name="CartEmptyTitleTextBlock" FontSize="15" FontWeight="Black"
                                           Foreground="{StaticResource StoreTextBrush}"
                                           Text="Корзина пока пуста"/>
                                <TextBlock x:Name="CartEmptySubtitleTextBlock" Margin="0,7,0,0" FontSize="12" LineHeight="18"
                                           Foreground="{StaticResource StoreMutedBrush}"
                                           TextWrapping="Wrap"
                                           Text="Добавьте товары из каталога, и здесь появятся количество, цена и итоговая сумма."/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding CartItemsVisibility}">
                            <ItemsControl ItemsSource="{Binding CartItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10" Padding="13"
                                                Background="{StaticResource StoreSurfaceAltBrush}"
                                                BorderThickness="0" CornerRadius="16">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Width="70" Height="70"
                                                        Background="White"
                                                        BorderBrush="{StaticResource StoreAccentLineBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        ClipToBounds="True">
                                                    <Image Source="{Binding ProductImage}"
                                                           Stretch="UniformToFill"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           SnapsToDevicePixels="True"/>
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock FontSize="14" FontWeight="Bold"
                                                               Foreground="{StaticResource StoreTextBrush}"
                                                               Text="{Binding ProductTitle}"/>
                                                    <TextBlock Margin="0,4,0,0" FontSize="11.5"
                                                               Foreground="{StaticResource StoreMutedBrush}"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding ProductMetaText}"/>
                                                    <TextBlock Margin="0,5,0,0" FontSize="12"
                                                               Foreground="{StaticResource StoreMutedBrush}"
                                                               Text="{Binding DisplayUnitPrice}"/>
                                                </StackPanel>
                                                <Button Grid.Column="3"
                                                        Width="30" Height="30"
                                                        VerticalAlignment="Top"
                                                        Click="RemoveCartItemButton_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="#FFFFF1F6"/>
                                                            <Setter Property="BorderBrush" Value="#FFFFCBDA"/>
                                                            <Setter Property="BorderThickness" Value="1.5"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="Root"
                                                                                Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="10">
                                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Root" Property="Background" Value="#FFFFDFEC"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                               Foreground="{StaticResource StoreAccentBrush}"
                                                               Text="&#xE74D;"/>
                                                </Button>
                                                <Grid Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,11,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Width="30" Height="30"
                                                            Click="DecreaseCartItemButton_Click">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Cursor" Value="Hand"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="Root" CornerRadius="10">
                                                                                <Border.Background>
                                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                                        <GradientStop Offset="0" Color="#FFFFE8F0"/>
                                                                                        <GradientStop Offset="1" Color="#FFFFD0E0"/>
                                                                                    </LinearGradientBrush>
                                                                                </Border.Background>
                                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                                  VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Button.Style>
                                                        <TextBlock FontSize="16" FontWeight="Black"
                                                                   Foreground="{StaticResource StoreAccentDarkBrush}"
                                                                   Text="−"/>
                                                    </Button>
                                                    <Border Grid.Column="1"
                                                            Width="36" Height="30" Margin="6,0"
                                                            Background="White"
                                                            BorderBrush="{StaticResource StoreAccentLineBrush}"
                                                            BorderThickness="1" CornerRadius="9">
                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontSize="13" FontWeight="Black"
                                                                   Text="{Binding Quantity}"/>
                                                    </Border>
                                                    <Button Grid.Column="2"
                                                            Width="30" Height="30"
                                                            Click="IncreaseCartItemButton_Click">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Cursor" Value="Hand"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="Root" CornerRadius="10">
                                                                                <Border.Background>
                                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                                        <GradientStop Offset="0" Color="#FFEC5A8D"/>
                                                                                        <GradientStop Offset="1" Color="#FFD83F77"/>
                                                                                    </LinearGradientBrush>
                                                                                </Border.Background>
                                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                                  VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Button.Style>
                                                        <TextBlock FontSize="16" FontWeight="Black"
                                                                   Foreground="White" Text="+"/>
                                                    </Button>
                                                    <TextBlock Grid.Column="3"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                                               FontSize="15" FontWeight="Black"
                                                               Foreground="{StaticResource StoreTextBrush}"
                                                               Text="{Binding DisplayLineTotal}"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="14,12,14,16" Padding="14"
                            Background="{StaticResource StoreSurfaceAltBrush}"
                            BorderThickness="0" CornerRadius="16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="28" Height="28" CornerRadius="8"
                                        Background="#FFFFE5EF">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{StaticResource StoreAccentBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Text="&#xE7BF;"/>
                                </Border>
                                <TextBlock x:Name="CheckoutPanelTitleTextBlock" Margin="8,0,0,0"
                                           FontSize="14"
                                           FontWeight="Black"
                                           Foreground="{StaticResource StoreTextBrush}"
                                           Text="Оформление"/>
                            </StackPanel>
                            <DockPanel>
                                <TextBlock x:Name="CartTotalLabelTextBlock" DockPanel.Dock="Left" VerticalAlignment="Center"
                                           FontSize="13" Foreground="{StaticResource StoreMutedBrush}"
                                           Text="Итоговая сумма"/>
                                <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                           FontSize="22" FontWeight="Black"
                                           Foreground="{StaticResource StoreTextBrush}"
                                           Text="{Binding CartTotalText, Converter={StaticResource CurrencyLabelConverter}}"/>
                            </DockPanel>
                            <TextBlock x:Name="CheckoutStatusTextBlock"
                                       Margin="0,12,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource StoreAccentBrush}"
                                       TextWrapping="Wrap"/>
                            <Button x:Name="CheckoutOrderButton"
                                     Margin="0,12,0,0"
                                     IsEnabled="{Binding CanCheckout}"
                                     Click="CheckoutOrderButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Root" CornerRadius="13" Height="44">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Offset="0" Color="#FFEC5A8D"/>
                                                                <GradientStop Offset="1" Color="#FFD83F77"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="16" ShadowDepth="0"
                                                                              Color="#FFEC5A8D" Opacity="0.40"/>
                                                        </Border.Effect>
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Root" Property="Opacity" Value="0.90"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               Margin="0,0,8,0" VerticalAlignment="Center"
                                               Text="&#xE7BF;"/>
                                    <TextBlock x:Name="CheckoutOrderButtonTextBlock"
                                               Text="Оформить заказ"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Background="#5E17233A"
              Visibility="{Binding ProductDetailsOverlayVisibility}"
              d:Visibility="Collapsed"
              MouseDown="ProductDetailsOverlay_MouseDown">
            <Border Width="1060"
                    MaxWidth="1060"
                    Margin="24"
                    Padding="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#FBFFFFFF"
                    BorderBrush="#FFF0D6E2"
                    BorderThickness="1.4"
                    CornerRadius="34"
                    Effect="{StaticResource StoreCardShadow}">
                <Grid DataContext="{Binding SelectedProductPreview}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.08*"/>
                        <ColumnDefinition Width="0.92*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,16,0"
                            Padding="8"
                            Background="#FFFFFBFD"
                            BorderBrush="#FFF5DDE7"
                            BorderThickness="1"
                            CornerRadius="28">
                        <Border Background="White"
                                BorderBrush="#FFF4E3EB"
                                BorderThickness="1"
                                CornerRadius="24"
                                ClipToBounds="True">
                            <Grid>
                                <Rectangle Fill="#FFFFFBFD"/>
                                <Image Source="{Binding ProductImage}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="20"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Grid>
                        </Border>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Padding="12,6"
                                    Background="{Binding CategoryBrush}"
                                    BorderBrush="#40FFFFFF"
                                    BorderThickness="1"
                                    HorizontalAlignment="Left"
                                    CornerRadius="14">
                                <TextBlock FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{Binding CategoryTextBrush}"
                                           Text="{Binding DisplayCategoryName}"/>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <ToggleButton Width="38"
                                              Height="38"
                                              Margin="0,0,10,0"
                                              VerticalAlignment="Center"
                                              Style="{DynamicResource FavoriteToggleStyle}"
                                              IsChecked="{Binding IsFavorite, Mode=TwoWay}"/>
                                <Button Width="38"
                                        Height="38"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource IconButtonStyle}"
                                        Click="CloseProductDetailsButton_Click">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="13"
                                               Foreground="{StaticResource StoreTextBrush}"
                                               Text="&#xE711;"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="1" Margin="0,20,0,0">
                            <TextBlock FontSize="34"
                                       FontWeight="Black"
                                       LineHeight="40"
                                       Foreground="{StaticResource StoreTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding ProductTitle}"/>
                            <TextBlock x:Name="ProductDetailsIntroTextBlock"
                                       Margin="0,12,0,0"
                                       FontSize="15"
                                       LineHeight="24"
                                       Foreground="{StaticResource StoreMutedBrush}"
                                       TextWrapping="Wrap"
                                       Text="Нежный товар для малыша с мягкой тканью, приятной фактурой и аккуратной отделкой."/>
                        </StackPanel>

                        <Grid Grid.Row="2" Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Margin="0,0,10,10"
                                    Padding="14"
                                    Background="#FFFFF7FA"
                                    BorderBrush="#FFF2DCE6"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock x:Name="ProductDetailsMaterialLabelTextBlock"
                                               FontSize="11.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource StoreMutedBrush}"
                                               Text="Материал"/>
                                    <TextBlock Margin="0,6,0,0"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource StoreTextBrush}"
                                               Text="{Binding FabricType}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="10,0,0,10"
                                    Padding="14"
                                    Background="#FFFFF7FA"
                                    BorderBrush="#FFF2DCE6"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock x:Name="ProductDetailsColorLabelTextBlock"
                                               FontSize="11.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource StoreMutedBrush}"
                                               Text="Цвет"/>
                                    <TextBlock Margin="0,6,0,0"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource StoreTextBrush}"
                                               Text="{Binding Color}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Margin="0,0,10,10"
                                    Padding="14"
                                    Background="#FFFFF7FA"
                                    BorderBrush="#FFF2DCE6"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock x:Name="ProductDetailsAmountLabelTextBlock"
                                               FontSize="11.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource StoreMutedBrush}"
                                               Text="Расход ткани"/>
                                    <TextBlock Margin="0,6,0,0"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource StoreTextBrush}"
                                               Text="{Binding FabricAmountLabel}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="10,0,0,10"
                                    Padding="14"
                                    Background="#FFFFF7FA"
                                    BorderBrush="#FFF2DCE6"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock x:Name="ProductDetailsPricePerMeterLabelTextBlock"
                                               FontSize="11.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource StoreMutedBrush}"
                                               Text="Цена за метр"/>
                                    <TextBlock Margin="0,6,0,0"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource StoreTextBrush}"
                                               Text="{Binding PricePerM, StringFormat={}{0:0.##} MDL}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2"
                                    Grid.ColumnSpan="2"
                                    Margin="0,0,0,0"
                                    Padding="16"
                                    Background="#FFFFEFF5"
                                    BorderBrush="#FFF2D6E4"
                                    BorderThickness="1"
                                    CornerRadius="20">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock x:Name="ProductDetailsTotalLabelTextBlock"
                                                   FontSize="11.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource StoreMutedBrush}"
                                                   Text="Итоговая стоимость"/>
                                        <TextBlock Margin="0,7,0,0"
                                                   FontSize="28"
                                                   FontWeight="Black"
                                                   Foreground="{StaticResource StoreAccentBrush}"
                                                   Text="{Binding DisplayPrice}"/>
                                    </StackPanel>
                                    <Border DockPanel.Dock="Right"
                                            Width="54"
                                            Height="54"
                                            Margin="14,0,0,0"
                                            Background="#FFFFFBFD"
                                            BorderBrush="#FFF4D8E5"
                                            BorderThickness="1"
                                            CornerRadius="18">
                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                   FontSize="24"
                                                   Foreground="{StaticResource StoreAccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="&#xE7BF;"/>
                                    </Border>
                                </DockPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="4" Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Height="48"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="AddSelectedProductToCartButton_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Text="{Binding CartButtonIconGlyph}"/>
                                    <TextBlock VerticalAlignment="Center"
                                               Text="{Binding CartButtonText}"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    Height="48"
                                    Background="White"
                                    BorderBrush="{StaticResource StoreAccentLineBrush}"
                                    BorderThickness="1"
                                    Foreground="{StaticResource StoreTextBrush}"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="CloseProductDetailsButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="14">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource StoreAccentSoftBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock x:Name="ProductDetailsCloseButtonTextBlock"
                                           Text="Закрыть"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Background="#6E1D2438"
              Visibility="{Binding GuideOverlayVisibility}"
              d:Visibility="Collapsed"
              MouseDown="GuideOverlay_MouseDown">
            <Border Width="1120"
                    MaxWidth="1120"
                    Height="760"
                    MaxHeight="760"
                    Margin="26"
                    Padding="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#F8FFFCFE"
                    BorderBrush="#FFF0D6E3"
                    BorderThickness="1.4"
                    CornerRadius="36"
                    SnapsToDevicePixels="True"
                    Effect="{StaticResource StoreCardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="6,2,6,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Padding="16,8"
                                Background="#FFFFFBFD"
                                BorderBrush="#FFF4DFE8"
                                BorderThickness="1"
                                CornerRadius="18"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="28"
                                        Height="28"
                                        Background="#FFFFE7F0"
                                        BorderBrush="#FFF7D9E5"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="13"
                                               Foreground="{StaticResource StoreAccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="&#xE946;"/>
                                </Border>
                                <TextBlock Margin="10,0,0,0"
                                           FontSize="16"
                                           FontWeight="Black"
                                           Foreground="{StaticResource StoreTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="{Binding GuideOverlayTitle}"/>
                            </StackPanel>
                        </Border>

                        <Button Grid.Column="1"
                                Width="40"
                                Height="40"
                                Style="{StaticResource IconButtonStyle}"
                                Click="CloseGuideOverlayButton_Click">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       Foreground="{StaticResource StoreTextBrush}"
                                       Text="&#xE711;"/>
                        </Button>
                    </Grid>

                    <Border Grid.Row="1"
                            Padding="10"
                            Background="#FFFFFBFD"
                            BorderBrush="#FFF2DEE8"
                            BorderThickness="1"
                            CornerRadius="30">
                        <Border Padding="10"
                                Background="White"
                                BorderBrush="#FFF5E3EC"
                                BorderThickness="1"
                                CornerRadius="24"
                                ClipToBounds="True">
                            <Grid Background="#FFFFFBFD">
                                <Image Source="{Binding CurrentGuideSlideImage}"
                                       Stretch="Uniform"
                                       Margin="12"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       SnapsToDevicePixels="True"/>
                            </Grid>
                        </Border>
                    </Border>

                    <Border Grid.Row="2"
                            Margin="0,14,0,0"
                            Padding="14,12"
                            Background="#F8FFFDFE"
                            BorderBrush="#FFF1DEE8"
                            BorderThickness="1"
                            CornerRadius="26">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Height="42"
                                    Padding="18,0"
                                    Background="White"
                                    BorderBrush="{StaticResource StoreAccentLineBrush}"
                                    BorderThickness="1"
                                    Foreground="{StaticResource StoreAccentBrush}"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    IsEnabled="{Binding CanGoGuidePrevious}"
                                    Click="GuidePreviousButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="21">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#FFFFF2F7"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="13"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Text="&#xE72B;"/>
                                    <TextBlock VerticalAlignment="Center"
                                               Text="{Binding GuidePreviousButtonText}"/>
                                </StackPanel>
                            </Button>

                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <ItemsControl ItemsSource="{Binding GuideDots}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="{Binding Width}"
                                                    Height="10"
                                                    Margin="0,0,8,0"
                                                    Background="{Binding Fill}"
                                                    CornerRadius="5"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Margin="0,10,0,0"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource StoreMutedBrush}"
                                           HorizontalAlignment="Center"
                                           Text="{Binding GuideSlideCaption}"/>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Height="42"
                                    Padding="18,0"
                                    Background="{StaticResource StoreAccentBrush}"
                                    BorderBrush="{StaticResource StoreAccentBrush}"
                                    BorderThickness="1"
                                    Foreground="White"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    IsEnabled="{Binding CanGoGuideNext}"
                                    Click="GuideNextButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="21">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="16"
                                                                  ShadowDepth="0"
                                                                  Color="#44EC5A8D"
                                                                  Opacity="0.35"/>
                                            </Border.Effect>
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center"
                                               Text="{Binding GuideNextButtonText}"/>
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="13"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="&#xE72A;"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
