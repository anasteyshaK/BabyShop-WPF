<Window x:Class="BabyShop.UserMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BabyShop"
        xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
        mc:Ignorable="d"
        Title="Baby Shop"
        Width="1600"
        Height="940"
        MinWidth="1280"
        MinHeight="820"
        Loaded="Window_Loaded"
        StateChanged="Window_StateChanged"
        SizeChanged="Window_SizeChanged"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <local:CurrencyLabelConverter x:Key="CurrencyLabelConverter"/>
        <!-- ══════════════════  COLOUR PALETTE  ══════════════════ -->
        <SolidColorBrush x:Key="StoreBackgroundBrush"  Color="#FFF9F3F6"/>
        <SolidColorBrush x:Key="StoreCardBrush"        Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="StoreAccentBrush"      Color="#FFEC5A8D"/>
        <SolidColorBrush x:Key="StoreAccentDarkBrush"  Color="#FFD83F77"/>
        <SolidColorBrush x:Key="StoreAccentSoftBrush"  Color="#FFFFF1F6"/>
        <SolidColorBrush x:Key="StoreAccentLineBrush"  Color="#FFF0DDE5"/>
        <SolidColorBrush x:Key="StoreTextBrush"        Color="#FF17233A"/>
        <SolidColorBrush x:Key="StoreMutedBrush"       Color="#FF7B8496"/>
        <SolidColorBrush x:Key="StoreSuccessBrush"     Color="#FF32B47A"/>
        <SolidColorBrush x:Key="StoreOverlayBrush"     Color="#5C17233A"/>
        <SolidColorBrush x:Key="StoreSurfaceAltBrush"  Color="#FFFDF7FA"/>

        <DropShadowEffect x:Key="StoreCardShadow"
                          BlurRadius="24" ShadowDepth="0"
                          Opacity="0.07" Color="#FFEC5A8D"/>
        <DropShadowEffect x:Key="StoreHeaderShadow"
                          BlurRadius="16" ShadowDepth="2"
                          Direction="270" Opacity="0.06" Color="#FF000000"/>

        <!-- NAV BUTTON – transparent, hover tint -->
        <Style x:Key="HeaderNavButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource StoreTextBrush}"/>
            <Setter Property="Padding"          Value="14,0"/>
            <Setter Property="Height"           Value="38"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource StoreAccentSoftBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderNavActiveButtonStyle" TargetType="Button"
               BasedOn="{StaticResource HeaderNavButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource StoreAccentBrush}"/>
            <Setter Property="Background" Value="{StaticResource StoreAccentSoftBrush}"/>
        </Style>

        <!-- ICON BUTTON -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource StoreAccentSoftBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NotificationCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource StoreAccentLineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- PRIMARY ACTION BUTTON -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource StoreAccentBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="20,0"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource StoreAccentDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProductButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource StoreAccentBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="0,0"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TinyGhostButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="{StaticResource StoreTextBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource StoreAccentLineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="MinWidth"        Value="32"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource StoreAccentSoftBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderLanguageButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource StoreAccentSoftBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SIDEBAR CARD – transparent, no border -->
        <Style x:Key="SidebarCardStyle" TargetType="Border">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
        </Style>

        <!-- PRODUCT CARD – white, shadow, NO border -->
        <Style x:Key="ProductCardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource StoreCardBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius"    Value="20"/>
            <Setter Property="Padding"         Value="14"/>
            <Setter Property="Effect"          Value="{StaticResource StoreCardShadow}"/>
        </Style>

        <DataTemplate x:Key="StoreProductCardTemplate">
            <Border Margin="0,0,12,14"
                    Cursor="Hand"
                    MouseLeftButtonUp="ProductCard_MouseLeftButtonUp"
                    Style="{StaticResource ProductCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="210"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#FFFAF4F7"
                            BorderThickness="0"
                            CornerRadius="14"
                            ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding ProductImage}"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <Border Margin="10"
                                    Padding="7,3"
                                    Background="{Binding CategoryBrush}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    CornerRadius="8">
                                <TextBlock FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding CategoryTextBrush}"
                                           Text="{Binding DisplayCategoryName}"/>
                            </Border>
                            <ToggleButton Margin="10"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Top"
                                          Style="{DynamicResource FavoriteToggleStyle}"
                                          IsChecked="{Binding IsFavorite, Mode=TwoWay}"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="0,12,0,0">
                        <TextBlock FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource StoreTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding ProductTitle}"/>
                        <TextBlock Margin="0,5,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource StoreMutedBrush}"
                                   Text="{Binding FabricType}"/>
                        <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                            <TextBlock FontSize="12"
                                       Foreground="{StaticResource StoreMutedBrush}"
                                       Text="{Binding Color}"/>
                            <TextBlock Margin="6,0"
                                       FontSize="12"
                                       Foreground="{StaticResource StoreMutedBrush}"
                                       Text="•"/>
                            <TextBlock FontSize="12"
                                       Foreground="{StaticResource StoreMutedBrush}"
                                       Text="{Binding FabricAmountLabel}"/>
                        </StackPanel>
                        <TextBlock Margin="0,9,0,0"
                                   FontSize="20"
                                   FontWeight="Black"
                                   Foreground="{StaticResource StoreTextBrush}"
                                   Text="{Binding DisplayPrice}"/>
                    </StackPanel>

                    <Button Grid.Row="2"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Stretch"
                            Background="{Binding CartButtonBackground}"
                            Foreground="{Binding CartButtonForeground}"
                            Style="{StaticResource ProductButtonStyle}"
                            Click="AddToCartButton_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       Margin="0,0,7,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding CartButtonIconGlyph}"/>
                            <TextBlock Text="{Binding CartButtonText}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- CATEGORY ROW BUTTON -->
        <Style x:Key="CategoryRowButtonStyle" TargetType="Button">
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="BorderThickness"       Value="0"/>
            <Setter Property="Padding"               Value="6,7"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource StoreAccentSoftBrush}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource StoreAccentSoftBrush}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- FAVOURITE TOGGLE -->
        <Style x:Key="FavoriteToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width"  Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root" Background="White" BorderThickness="0" CornerRadius="15">
                            <TextBlock x:Name="HeartGlyph"
                                       FontFamily="Segoe UI Symbol" FontSize="15"
                                       Foreground="{StaticResource StoreAccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Text="♡"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource StoreAccentSoftBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource StoreAccentSoftBrush}"/>
                                <Setter TargetName="HeartGlyph" Property="Text" Value="♥"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════ STYLED SORT COMBOBOX ══════════════════ -->
        <Style x:Key="StoreSortComboBox" TargetType="ComboBox">
            <Setter Property="Background"          Value="White"/>
            <Setter Property="Foreground"          Value="{StaticResource StoreTextBrush}"/>
            <Setter Property="BorderBrush"         Value="{StaticResource StoreAccentLineBrush}"/>
            <Setter Property="BorderThickness"     Value="1"/>
            <Setter Property="FontSize"            Value="13"/>
            <Setter Property="FontWeight"          Value="SemiBold"/>
            <Setter Property="Height"              Value="38"/>
            <Setter Property="Padding"             Value="12,0"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Shell"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="22"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="ContentSite"
                                                      Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"/>
                                    <Path Grid.Column="1"
                                          Data="M 0 0 L 5 5 L 10 0"
                                          Stroke="{StaticResource StoreMutedBrush}"
                                          StrokeThickness="1.6"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  Opacity="0"
                                                  IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="False"
                                                  ClickMode="Press"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDown"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="220"
                                        Background="White"
                                        BorderBrush="{StaticResource StoreAccentLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Color="#22000000" Opacity="0.10"/>
                                    </Border.Effect>
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Shell" Property="BorderBrush" Value="{StaticResource StoreAccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground"  Value="{StaticResource StoreTextBrush}"/>
                        <Setter Property="FontSize"    Value="13"/>
                        <Setter Property="Padding"     Value="14,9"/>
                        <Setter Property="Cursor"      Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd"
                                            Background="Transparent"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource StoreAccentSoftBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource StoreAccentBrush}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{StaticResource StoreAccentLineBrush}" CornerRadius="3"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource StoreBackgroundBrush}">
        <ScrollViewer x:Name="RootScrollViewer"
                      SizeChanged="RootScrollViewer_SizeChanged"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid x:Name="ViewportContentGrid"
                  HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ══════════════  HEADER – flat white bar  ══════════════ -->
                <Border Grid.Row="0"
                        Padding="24,0"
                        Height="84"
                        Background="White"
                        BorderThickness="0"
                        Effect="{StaticResource StoreHeaderShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Logo -->
                        <Grid VerticalAlignment="Top" Margin="0,0,0,0">
                            <Image x:Name="HeaderLogoImage"
                                   Source="/Assets/babyshop-logo.png"
                                   Width="154"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" Height="132" Margin="-10,-22,0,0"/>
                        </Grid>

                        <!-- Search -->
                        <Border Grid.Column="1"
                                Margin="28,0,24,0" Height="42" MaxWidth="500"
                                Padding="16,0,14,0"
                                Background="#FFF5F5F5"
                                BorderThickness="0" CornerRadius="12"
                                HorizontalAlignment="Stretch" VerticalAlignment="Center">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SearchPlaceholderTextBlock" Margin="2,0,0,0" VerticalAlignment="Center"
                                           Foreground="{StaticResource StoreMutedBrush}" FontSize="13"
                                           IsHitTestVisible="False"
                                           Text="Поиск товаров для малышей..."
                                           Visibility="{Binding SearchPlaceholderVisibility}"/>
                                <TextBox x:Name="SearchBox"
                                         Grid.Column="0"
                                         Background="Transparent" BorderThickness="0"
                                         Padding="0" Margin="0,0,8,0"
                                         VerticalContentAlignment="Center"
                                         Foreground="{StaticResource StoreTextBrush}" FontSize="13"
                                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="1"
                                           FontFamily="Segoe MDL2 Assets" FontSize="15"
                                           Foreground="{StaticResource StoreMutedBrush}"
                                           VerticalAlignment="Center" Text="&#xE721;"/>
                            </Grid>
                        </Border>

                        <!-- Nav -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource HeaderNavActiveButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Margin="0,0,6,0" VerticalAlignment="Center" Text="&#xE80F;"/>
                                    <TextBlock x:Name="HomeNavTextBlock" Text="Главная" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="4,0,0,0"
                                    Style="{StaticResource HeaderNavButtonStyle}"
                                    Click="FavoritesButton_Click">
                                <TextBlock x:Name="FavoritesNavTextBlock" Text="Избранное" VerticalAlignment="Center"/>
                            </Button>
                            <Button Margin="4,0,0,0"
                                    Style="{StaticResource HeaderNavButtonStyle}"
                                    Click="MyOrdersButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Margin="0,0,6,0" VerticalAlignment="Center" Text="&#xE8A1;"/>
                                    <TextBlock x:Name="MyOrdersNavTextBlock" Text="Мои заказы" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Right icons -->
                        <StackPanel Grid.Column="3" Margin="16,0,0,0"
                                    Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid>
                                <!-- ✅ ИЗМЕНЕНО: иконка телефона вместо колокольчика -->
                                <Button x:Name="NotificationsButton"
                                        Style="{StaticResource IconButtonStyle}"
                                        Click="NotificationsButton_Click">
