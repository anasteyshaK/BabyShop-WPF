<Window x:Class="BabyShop.FavoritesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Избранное — BabyShop"
        Width="1600"
        Height="920"
        MinWidth="1280"
        MinHeight="840"
        Background="#FFF7F0F4"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">

    <Window.Resources>

        <SolidColorBrush x:Key="Bg"          Color="#FFF7F0F4"/>
        <SolidColorBrush x:Key="Surface"     Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="SurfaceRose" Color="#FFFFF8FA"/>
        <SolidColorBrush x:Key="Accent"      Color="#FFF4567E"/>
        <SolidColorBrush x:Key="AccentDark"  Color="#FFE03D6B"/>
        <SolidColorBrush x:Key="AccentSoft"  Color="#FFFEECF2"/>
        <SolidColorBrush x:Key="AccentMid"   Color="#FFFFD6E4"/>
        <SolidColorBrush x:Key="Line"        Color="#FFF2DBE6"/>
        <SolidColorBrush x:Key="Text"        Color="#FF14202F"/>
        <SolidColorBrush x:Key="TextSub"     Color="#FF4A5568"/>
        <SolidColorBrush x:Key="Muted"       Color="#FF96A0B5"/>
        <SolidColorBrush x:Key="Purple"      Color="#FF7C5CE9"/>
        <SolidColorBrush x:Key="PurpleSoft"  Color="#FFF0EBFF"/>

        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FFF56E98"/>
            <GradientStop Offset="1" Color="#FFEC3B70"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0" Color="#FFFFFFFF"/>
            <GradientStop Offset="1" Color="#FFFFF9FB"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PanelPink" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#FFFEE6EE"/>
            <GradientStop Offset="1" Color="#FFFEF0F5"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PanelBeige" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#FFFFF6EC"/>
            <GradientStop Offset="1" Color="#FFFEF9F5"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PanelPurple" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#FFF3EEFF"/>
            <GradientStop Offset="1" Color="#FFFAF8FF"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="IconPinkGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FFF56E98"/>
            <GradientStop Offset="1" Color="#FFEC3B70"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="IconBeigeGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FFFF9A5C"/>
            <GradientStop Offset="1" Color="#FFEE7A38"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="IconPurpleGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FF9C7EF0"/>
            <GradientStop Offset="1" Color="#FF7C5CE9"/>
        </LinearGradientBrush>

        <DropShadowEffect x:Key="ShellShadow" BlurRadius="40" ShadowDepth="0" Color="#1AF0C0D0" Opacity="0.22"/>
        <DropShadowEffect x:Key="CardShadow"  BlurRadius="18" ShadowDepth="0" Color="#18F4A0C0" Opacity="0.14"/>
        <DropShadowEffect x:Key="BtnShadow"   BlurRadius="14" ShadowDepth="0" Color="#42F4567E" Opacity="0.28"/>
        <DropShadowEffect x:Key="PillShadow"  BlurRadius="8"  ShadowDepth="0" Color="#20F4567E" Opacity="0.16"/>
        <DropShadowEffect x:Key="IconShadow"  BlurRadius="10" ShadowDepth="0" Color="#30F4567E" Opacity="0.22"/>

        <ControlTemplate x:Key="ComboBoxToggleTemplate" TargetType="ToggleButton">
            <Border x:Name="Bd" Background="Transparent" BorderThickness="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="28"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Grid.Column="0" Margin="0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Path Grid.Column="1" Data="M 0 0 L 5 5 L 10 0" Stroke="#FFCCCDD6" StrokeThickness="1.6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </ControlTemplate>

        <Style x:Key="FlatComboBox" TargetType="ComboBox">
            <Setter Property="Background"          Value="{StaticResource Surface}"/>
            <Setter Property="BorderBrush"         Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness"     Value="1.2"/>
            <Setter Property="Foreground"          Value="{StaticResource Text}"/>
            <Setter Property="FontSize"            Value="14"/>
            <Setter Property="FontWeight"          Value="Normal"/>
            <Setter Property="Height"              Value="52"/>
            <Setter Property="Padding"             Value="16,0"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Shell"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="16">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="ContentSite"
                                                      Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"/>
                                    <Path Grid.Column="1" Data="M 0 0 L 5 5 L 10 0" Stroke="{StaticResource Muted}" StrokeThickness="1.8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <ToggleButton Grid.ColumnSpan="2" Opacity="0"
                                                  IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="False" ClickMode="Press"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border x:Name="DropDown" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="240"
                                        Background="White" BorderBrush="{StaticResource Line}" BorderThickness="1.2" CornerRadius="14" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Color="#22000000" Opacity="0.12"/>
                                    </Border.Effect>
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Shell" Property="BorderBrush" Value="{StaticResource AccentMid}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        <Setter Property="FontSize"   Value="14"/>
                        <Setter Property="Padding"    Value="16,10"/>
                        <Setter Property="Cursor"     Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoft}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Height"          Value="52"/>
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSub}"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="R"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="R" Property="Background"  Value="{StaticResource AccentSoft}"/>
                                <Setter TargetName="R" Property="BorderBrush" Value="{StaticResource AccentMid}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.985" ScaleY="0.985"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
            <Setter Property="Background"  Value="{StaticResource AccentGradient}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="Effect"      Value="{StaticResource BtnShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="R"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="R" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.985" ScaleY="0.985"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource CardGradient}"/>
            <Setter Property="CornerRadius"    Value="22"/>
            <Setter Property="Padding"         Value="14"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect"          Value="{StaticResource CardShadow}"/>
        </Style>

        <Style x:Key="HeartToggle" TargetType="ToggleButton">
            <Setter Property="Width"  Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="White"
                                BorderBrush="{StaticResource Line}"
                                BorderThickness="1.2"
                                CornerRadius="20"
                                Effect="{StaticResource PillShadow}">
                            <TextBlock x:Name="Glyph"
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="16"
                                       Foreground="{StaticResource AccentMid}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="♡"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"  Value="{StaticResource AccentSoft}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentMid}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root"  Property="Background"  Value="{StaticResource AccentSoft}"/>
                                <Setter TargetName="Root"  Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter TargetName="Glyph" Property="Text"        Value="♥"/>
                                <Setter TargetName="Glyph" Property="Foreground"  Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width"  Value="5"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{StaticResource AccentMid}" CornerRadius="3"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource Bg}">
        <Border Margin="14"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Line}"
                BorderThickness="1"
                CornerRadius="32"
                Effect="{StaticResource ShellShadow}">
            <Grid Margin="28,22,28,22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ROW 0 — TOP BAR -->
                <Grid Grid.Row="0" Height="52">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="460"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource Surface}"
                            BorderBrush="{StaticResource Line}"
                            BorderThickness="1.2"
                            CornerRadius="16">
                        <Grid Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="17" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Text="&#xE721;"/>
                            <Grid Grid.Column="1" Margin="12,0,0,0">
                                <TextBox x:Name="SearchTextBox"
                                         Background="Transparent" BorderThickness="0"
                                         VerticalContentAlignment="Center" FontSize="14"
                                         Foreground="{StaticResource Text}"
                                         TextChanged="SearchTextBox_TextChanged"/>
                                <TextBlock IsHitTestVisible="False" VerticalAlignment="Center" FontSize="14"
                                           Foreground="{StaticResource Muted}" Text="Поиск в избранном"
                                           Visibility="{Binding SearchPlaceholderVisibility}"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <ComboBox Grid.Column="2" x:Name="SortComboBox"
                              Style="{StaticResource FlatComboBox}"
                              SelectionChanged="SortComboBox_SelectionChanged">
                        <ComboBoxItem Content="Сначала новые"  Tag="newest" IsSelected="True"/>
                        <ComboBoxItem Content="Сначала старые" Tag="oldest"/>
                        <ComboBoxItem Content="По названию"    Tag="title"/>
                        <ComboBoxItem Content="По цене"        Tag="price"/>
                    </ComboBox>

                    <Border Grid.Column="4" Height="52" Padding="16,0" CornerRadius="16"
                            Background="{StaticResource AccentSoft}" BorderBrush="{StaticResource AccentMid}" BorderThickness="1.2">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Border Width="30" Height="30" Background="{StaticResource AccentGradient}" CornerRadius="15" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe UI Symbol" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Text="♥"/>
                            </Border>
                            <TextBlock Margin="10,0,0,0" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Text="{Binding FavoritesCount}"/>
                            <TextBlock Margin="6,0,0,0"  FontSize="13" Foreground="{StaticResource TextSub}" VerticalAlignment="Center" Text="товаров"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ROW 1 — HEADER + BUTTONS -->
                <Grid Grid.Row="1" Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="286"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="230"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontSize="16" Foreground="#FFF8C4D4" Margin="2,4,8,0" VerticalAlignment="Center" Text="✦"/>
                            <TextBlock x:Name="TitleTextBlock" FontSize="44" FontWeight="Black" Foreground="{StaticResource Text}" VerticalAlignment="Center" Text="Избранное"/>
                            <Border Margin="16,0,0,0" Padding="14,5" VerticalAlignment="Center"
                                    Background="{StaticResource AccentSoft}" BorderBrush="{StaticResource AccentMid}" BorderThickness="1" CornerRadius="999">
                                <TextBlock x:Name="FavoritesBadgeTextBlock" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Accent}" Text="0 товаров"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Margin="26,6,0,0" FontSize="15" Foreground="{StaticResource Muted}" Text="Товары, которые вы сохранили"/>
                    </StackPanel>

                    <Button Grid.Column="1" Style="{StaticResource PrimaryBtn}" Click="AddAllToCartButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center" Text="&#xE7BF;"/>
                            <TextBlock FontWeight="SemiBold" VerticalAlignment="Center" Text="Добавить всё в корзину"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3" Style="{StaticResource GhostBtn}" Click="ClearFavoritesButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{StaticResource Muted}" Text="&#xE74D;"/>
                            <TextBlock VerticalAlignment="Center" Text="Очистить избранное"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- ROW 2 — PRODUCT CARDS -->
                <ScrollViewer Grid.Row="2" Margin="0,8,0,12" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding VisibleFavorites}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Margin" Value="0,0,16,16"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="148"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="44"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="148" Height="148" Background="{StaticResource SurfaceRose}" CornerRadius="16" ClipToBounds="True">
                                                    <Image Source="{Binding ProductImage}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="14,4,8,0">
                                                    <Border Padding="10,4" HorizontalAlignment="Left" CornerRadius="999"
                                                            Background="{Binding CategoryBrush}" BorderBrush="{Binding CategoryBorderBrush}" BorderThickness="1">
                                                        <TextBlock FontSize="11" FontWeight="Bold" Foreground="{Binding CategoryTextBrush}" Text="{Binding CategoryName}"/>
                                                    </Border>
                                                    <TextBlock Margin="0,12,0,0" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text}" TextWrapping="Wrap" LineHeight="22" Text="{Binding ProductTitle}"/>
                                                    <TextBlock Margin="0,8,0,0"  FontSize="12" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Text="{Binding FavoriteMetaText}"/>
                                                    <TextBlock Margin="0,12,0,0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Text}" Text="{Binding DisplayPrice}"/>
                                                </StackPanel>
                                                <ToggleButton Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Top"
                                                              Style="{StaticResource HeartToggle}" IsChecked="{Binding IsFavorite, Mode=TwoWay}"/>
                                            </Grid>
                                            <Button Grid.Row="1" Margin="0,14,0,0" Height="42" HorizontalAlignment="Stretch"
                                                    Style="{StaticResource PrimaryBtn}"
                                                    Background="{Binding CartButtonBackground}"
                                                    BorderBrush="Transparent"
                                                    Foreground="{Binding CartButtonForeground}"
                                                    Click="AddSingleToCartButton_Click">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" FontSize="13" VerticalAlignment="Center" Text="{Binding CartButtonIconGlyph}"/>
                                                    <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="{Binding CartButtonText}"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Margin="0,0,0,10" Padding="40" Background="White"
                                BorderBrush="{StaticResource Line}" BorderThickness="1.2" CornerRadius="22"
                                Visibility="{Binding EmptyStateVisibility}">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="60" Height="60" Background="{StaticResource AccentSoft}" CornerRadius="30" HorizontalAlignment="Center" Margin="0,0,0,14">
                                    <TextBlock FontFamily="Segoe UI Symbol" FontSize="26" Foreground="{StaticResource Accent}" HorizontalAlignment="Center" VerticalAlignment="Center" Text="♡"/>
                                </Border>
                                <TextBlock FontSize="22" FontWeight="Black" Foreground="{StaticResource Text}" HorizontalAlignment="Center" Text="Избранное пока пусто"/>
                                <TextBlock Margin="0,10,0,0" FontSize="14" Foreground="{StaticResource Muted}" HorizontalAlignment="Center" TextAlignment="Center"
                                           Text="Добавляйте товары сердечком — они появятся здесь."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ROW 3 — BOTTOM INFO PANELS -->
                <Grid Grid.Row="3" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Height="130"
                            Background="{StaticResource PanelPink}"
                            BorderBrush="{StaticResource Line}"
                            BorderThickness="1.1"
                            CornerRadius="22"
                            ClipToBounds="True">
                        <Grid>
                            <Viewbox Width="88" Height="88"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"
                                     Margin="0,0,18,0"
                                     Opacity="0.13">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#FFF4567E"
                                          Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.27 2 8.5 2 5.41 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.08 C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.41 22 8.5 c0 3.77-3.4 6.86-8.55 11.53L12 21.35z"/>
                                </Canvas>
                            </Viewbox>
                            <Ellipse Width="6" Height="6"
                                     Fill="#FFF4567E"
                                     Opacity="0.18"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Top"
                                     Margin="0,18,70,0"/>
                            <Ellipse Width="4" Height="4"
                                     Fill="#FFF4567E"
                                     Opacity="0.13"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Top"
                                     Margin="0,32,52,0"/>
                            <StackPanel Orientation="Horizontal"
                                        Margin="22,0,130,0"
                                        VerticalAlignment="Center">
                                <Border Width="54" Height="54"
                                        CornerRadius="27"
                                        Background="{StaticResource IconPinkGradient}"
                                        Effect="{StaticResource IconShadow}">
                                    <Viewbox Width="26" Height="26"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="White"
