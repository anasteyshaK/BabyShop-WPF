<Window x:Class="BabyShop.OrderDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Детали заказа"
        Width="1310"
        Height="860"
        MinWidth="1040"
        MinHeight="720"
        WindowStartupLocation="CenterOwner"
        Background="#FFF7F9"
        Loaded="Window_Loaded">
    <Window.Resources>
        <!-- Core palette -->
        <SolidColorBrush x:Key="AccentBrush"           Color="#F05B92"/>
        <SolidColorBrush x:Key="AccentStrongBrush"     Color="#EF4085"/>
        <SolidColorBrush x:Key="AccentSoftBrush"       Color="#FDEEF4"/>
        <SolidColorBrush x:Key="AccentSofterBrush"     Color="#FEF5F9"/>
        <SolidColorBrush x:Key="TextBrush"             Color="#1A2540"/>
        <SolidColorBrush x:Key="MutedBrush"            Color="#8992AA"/>
        <SolidColorBrush x:Key="LineBrush"             Color="#EDD8E4"/>
        <SolidColorBrush x:Key="SurfaceBrush"          Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PageBgBrush"           Color="#FFF7F9"/>

        <!-- Status colours -->
        <SolidColorBrush x:Key="PendingBgBrush"        Color="#FFF3D6"/>
        <SolidColorBrush x:Key="PendingFgBrush"        Color="#B07D10"/>
        <SolidColorBrush x:Key="ShippedBgBrush"        Color="#E6F1FC"/>
        <SolidColorBrush x:Key="ShippedFgBrush"        Color="#1F6FB5"/>
        <SolidColorBrush x:Key="CompletedBgBrush"      Color="#E8F7ED"/>
        <SolidColorBrush x:Key="CompletedFgBrush"      Color="#2A7D4A"/>

        <!-- в”Ђв”Ђ Info card (РљР»РёРµРЅС‚ / РђРґСЂРµСЃ / Р”Р°С‚С‹) в”Ђв”Ђ -->
        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="Background"       Value="White"/>
            <Setter Property="BorderBrush"      Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness"  Value="0,0,1,0"/>
            <Setter Property="Padding"          Value="20,14"/>
        </Style>

        <!-- в”Ђв”Ђ Soft button (РџРµС‡Р°С‚СЊ) в”Ђв”Ђ -->
        <Style x:Key="SoftButtonStyle" TargetType="Button">
            <Setter Property="Height"           Value="52"/>
            <Setter Property="Padding"          Value="28,0"/>
            <Setter Property="FontSize"         Value="17"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Foreground"       Value="{StaticResource TextBrush}"/>
            <Setter Property="Background"       Value="White"/>
            <Setter Property="BorderBrush"      Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- в”Ђв”Ђ Primary button (Р—Р°РєСЂС‹С‚СЊ) в”Ђв”Ђ -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SoftButtonStyle}">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource AccentBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- summary header row -->
            <RowDefinition Height="*"/>
            <!-- items list -->
            <RowDefinition Height="Auto"/>
            <!-- footer bar -->
        </Grid.RowDefinitions>

        <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
             ROW 0 вЂ” Summary header (Р—Р°РєР°Р· / РљР»РёРµРЅС‚ / РђРґСЂРµСЃ / Р”Р°С‚С‹ / РС‚РѕРіРѕ)
             в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Р—Р°РєР°Р· в„–  -->
                    <ColumnDefinition Width="200"/>
                    <!-- РљР»РёРµРЅС‚   -->
                    <ColumnDefinition Width="*"/>
                    <!-- РђРґСЂРµСЃ    -->
                    <ColumnDefinition Width="1.5*"/>
                    <!-- Р”Р°С‚Р° РЅР°С‡Р°Р»Р° -->
                    <ColumnDefinition Width="*"/>
                    <!-- Р”Р°С‚Р° РѕРєРѕРЅС‡Р°РЅРёСЏ -->
                    <ColumnDefinition Width="*"/>
                    <!-- РС‚РѕРіРѕ   -->
                    <ColumnDefinition Width="190"/>
                </Grid.ColumnDefinitions>

                <!-- Р—Р°РєР°Р· в„– + СЃС‚Р°С‚СѓСЃ -->
                <StackPanel Grid.Column="0"
                            Margin="20,16"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="OrderTitleTextBlock"
                               FontSize="28"
                               FontWeight="Black"
                               Foreground="{StaticResource TextBrush}"
                               Text="Р—Р°РєР°Р· в„–12"/>
                    <!-- Status badge -->
                    <Border x:Name="StatusBadgeBorder"
                            Margin="0,10,0,0"
                            Padding="10,5"
                            HorizontalAlignment="Left"
                            CornerRadius="999"
                            Background="{StaticResource PendingBgBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="StatusIconTextBlock"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0"
                                       FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE823;"/>
                            <TextBlock x:Name="StatusBadgeTextBlock"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PendingFgBrush}"
                                       Text="Pending"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- РљР»РёРµРЅС‚ -->
                <Border Grid.Column="1" Style="{StaticResource InfoCardStyle}" Padding="20,14">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="16"
                                       Margin="0,0,6,0"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE77B;"/>
                            <TextBlock x:Name="CustomerLabelTextBlock"
                                       FontSize="13"
                                       Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center"
                                       Text="РљР»РёРµРЅС‚"/>
                        </StackPanel>
                        <TextBlock x:Name="CustomerValueTextBlock"
                                   Margin="0,8,0,0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   Text="Anaa Lucruta"/>
                    </StackPanel>
                </Border>

                <!-- РђРґСЂРµСЃ РґРѕСЃС‚Р°РІРєРё -->
                <Border Grid.Column="2" Style="{StaticResource InfoCardStyle}" Padding="20,14">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="16"
                                       Margin="0,0,6,0"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE707;"/>
                            <TextBlock x:Name="AddressLabelTextBlock"
                                       FontSize="13"
                                       Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center"
                                       Text="РђРґСЂРµСЃ РґРѕСЃС‚Р°РІРєРё"/>
                        </StackPanel>
                        <TextBlock x:Name="AddressValueTextBlock"
                                   Margin="0,8,0,0"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"
                                   Text="Mircea cel batrin 18, 5/11, Chisinau, MD"/>
                    </StackPanel>
                </Border>

                <!-- Р”Р°С‚Р° РЅР°С‡Р°Р»Р° -->
                <Border Grid.Column="3" Style="{StaticResource InfoCardStyle}" Padding="20,14">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="16"
                                       Margin="0,0,6,0"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE787;"/>
                            <TextBlock x:Name="StartDateLabelTextBlock"
                                       FontSize="13"
                                       Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center"
                                       Text="Р”Р°С‚Р° РЅР°С‡Р°Р»Р°"/>
                        </StackPanel>
                        <TextBlock x:Name="StartDateValueTextBlock"
                                   Margin="0,8,0,0"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   Text="5/11/2026 12:00"/>
                    </StackPanel>
                </Border>

                <!-- Р”Р°С‚Р° РѕРєРѕРЅС‡Р°РЅРёСЏ -->
                <Border Grid.Column="4" Style="{StaticResource InfoCardStyle}" Padding="20,14">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="16"
                                       Margin="0,0,6,0"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE787;"/>
                            <TextBlock x:Name="EndDateLabelTextBlock"
                                       FontSize="13"
                                       Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center"
                                       Text="Р”Р°С‚Р° РѕРєРѕРЅС‡Р°РЅРёСЏ"/>
                        </StackPanel>
                        <TextBlock x:Name="EndDateValueTextBlock"
                                   Margin="0,8,0,0"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   Text="5/16/2026 12:00"/>
                    </StackPanel>
                </Border>

                <!-- РС‚РѕРіРѕ Рє РѕРїР»Р°С‚Рµ вЂ” СЂРѕР·РѕРІС‹Р№ Р°РєС†РµРЅС‚РЅС‹Р№ Р±Р»РѕРє -->
                <Border Grid.Column="5"
                        Background="{StaticResource AccentSoftBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1,0,0,0"
                        CornerRadius="0,20,20,0"
                        Padding="18,14">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TotalLabelTextBlock"
                                   FontSize="13"
                                   Foreground="{StaticResource AccentBrush}"
                                   Text="РС‚РѕРіРѕ Рє РѕРїР»Р°С‚Рµ"/>
                        <TextBlock x:Name="TotalValueTextBlock"
                                   Margin="0,6,0,0"
                                   FontSize="28"
                                   FontWeight="Black"
                                   Foreground="{StaticResource AccentStrongBrush}"
                                   Text="1 382.30"/>
                        <TextBlock x:Name="CurrencyTextBlock"
                                   Margin="0,4,0,0"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="MDL"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
             ROW 1 вЂ” РЎРѕСЃС‚Р°РІ Р·Р°РєР°Р·Р°
             в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
        <Border Grid.Row="1"
                Margin="0,14,0,0"
                Padding="16"
                Background="White"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Section title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2,2,0,0">
                    <Border Width="36" Height="36"
                            Background="{StaticResource AccentSoftBrush}"
                            CornerRadius="10"
                            Margin="0,0,10,0">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE719;"/>
                    </Border>
                    <TextBlock x:Name="ItemsSectionTitleTextBlock"
                               FontSize="22"
                               FontWeight="Black"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center"
                               Text="РЎРѕСЃС‚Р°РІ Р·Р°РєР°Р·Р°"/>
                </StackPanel>

                <!-- Items list -->
                <ScrollViewer Grid.Row="1"
                              Margin="0,12,0,0"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="OrderItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Item row card -->
                                <Border Margin="0,0,0,10"
                                        Background="White"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <!-- Image -->
                                            <ColumnDefinition Width="180"/>
                                            <!-- Name + meta -->
                                            <ColumnDefinition Width="*"/>
                                            <!-- РљРѕР»РёС‡РµСЃС‚РІРѕ -->
                                            <ColumnDefinition Width="130"/>
                                            <!-- Р¦РµРЅР° Р·Р° РµРґ. -->
                                            <ColumnDefinition Width="180"/>
                                            <!-- РЎСѓРјРјР° -->
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Product image -->
                                        <Border Width="160"
                                                Height="110"
                                                Margin="10"
                                                CornerRadius="12"
                                                BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1"
                                                ClipToBounds="True"
                                                Background="#FAF0F4">
                                            <Image Source="{Binding ImagePath}"
                                                   Stretch="UniformToFill"/>
                                        </Border>

                                        <!-- Name / Category / Fabric / Color -->
                                        <StackPanel Grid.Column="1"
                                                    Margin="14,0,10,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock FontSize="22"
                                                       FontWeight="Black"
                                                       Foreground="{StaticResource TextBrush}"
                                                       Text="{Binding ProductTitle}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBlock FontSize="14"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Margin="0,0,4,0"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           Text="&#xE14C;"/>
                                                <TextBlock FontSize="14"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Text="{Binding CategoryName}"/>
                                            </StackPanel>
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="14"
                                                       Foreground="{StaticResource TextBrush}"
                                                       Text="{Binding FabricType}"/>
                                            <TextBlock Margin="0,3,0,0" FontSize="14" Foreground="{StaticResource TextBrush}">
                                                <Run Text="Цвет: "/>
                                                <Run Text="{Binding Color}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- РљРѕР»РёС‡РµСЃС‚РІРѕ -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock HorizontalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Text="Количество"/>
                                            <Border Margin="0,8,0,0"
                                                    Padding="16,8"
                                                    HorizontalAlignment="Center"
                                                    Background="White"
                                                    BorderBrush="{StaticResource LineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontSize="18"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource TextBrush}"
                                                               Text="{Binding Quantity}"/>
                                                    <TextBlock FontSize="16"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               Margin="3,0,0,0"
                                                               Text=" шт."/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- Р¦РµРЅР° Р·Р° РµРґ. -->
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock HorizontalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Text="Цена за ед."/>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,12,0,0">
                                                <TextBlock FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource TextBrush}"
                                                           Text="{Binding UnitPrice, StringFormat=N2}"/>
                                                <TextBlock FontSize="16"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Margin="5,0,0,0"
                                                           VerticalAlignment="Bottom"
                                                           Text="MDL"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- РЎСѓРјРјР° -->
                                        <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock HorizontalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Text="Сумма"/>
                                            <Border Margin="0,8,0,0"
                                                    Padding="18,10"
                                                    HorizontalAlignment="Center"
                                                    Background="{StaticResource AccentSofterBrush}"
                                                    BorderBrush="{StaticResource LineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontSize="22"
                                                               FontWeight="Black"
                                                               Foreground="{StaticResource AccentStrongBrush}"
                                                               Text="{Binding LineTotal, StringFormat=N2}"/>
                                                    <TextBlock FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               Margin="5,0,0,0"
                                                               VerticalAlignment="Bottom"
                                                               Text="MDL"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
             ROW 2 вЂ” Footer bar
             в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
        <Border Grid.Row="2"
                Margin="0,14,0,0"
                Padding="18,14"
                Background="White"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Basket icon + counts -->
                    <ColumnDefinition Width="*"/>
                    <!-- Separator -->
                    <ColumnDefinition Width="1"/>
                    <!-- РС‚РѕРіРѕ -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Buttons -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Basket + counts -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="48"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="14"
                            Margin="0,0,14,0">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="22"
                                   FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE14D;"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="FooterPositionsTextBlock"
                                   FontSize="15"
                                   Foreground="{StaticResource TextBrush}">
                            <Run Text="Всего товаров: "/>
                            <Run x:Name="FooterPositionsValueRun"
                                 FontWeight="Bold"
                                 Text="4"/>
                        </TextBlock>
                        <TextBlock x:Name="FooterQuantityTextBlock"
                                   Margin="0,4,0,0"
                                   FontSize="15"
                                   Foreground="{StaticResource TextBrush}">
                            <Run Text="Общее количество: "/>
                            <Run x:Name="FooterQuantityValueRun"
                                 FontWeight="Bold"
                                 Text="4 С€С‚."/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Vertical separator -->
                <Border Grid.Column="1"
                        Width="1"
                        Background="{StaticResource LineBrush}"
                        Margin="20,4"/>

                <!-- РС‚РѕРіРѕ Рє РѕРїР»Р°С‚Рµ -->
                <StackPanel Grid.Column="2"
                            Margin="24,0"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="FooterTotalLabelTextBlock"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Text="РС‚РѕРіРѕ Рє РѕРїР»Р°С‚Рµ:"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock x:Name="FooterTotalValueTextBlock"
                                   FontSize="30"
                                   FontWeight="Black"
                                   Foreground="{StaticResource AccentStrongBrush}"
                                   Text="1 382.30"/>
                        <TextBlock FontSize="22"
                                   FontWeight="Black"
                                   Foreground="{StaticResource AccentStrongBrush}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Bottom"
                                   Text="MDL"/>
                    </StackPanel>
                </StackPanel>

                <!-- Print button -->
                <Button x:Name="PrintButton"
                        Grid.Column="3"
                        Margin="0,0,10,0"
                        Style="{StaticResource SoftButtonStyle}"
                        Click="PrintButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" Text="&#xE749;"/>
                        <TextBlock FontSize="16" VerticalAlignment="Center" Text="Печать"/>
                    </StackPanel>
                </Button>

                <!-- Close button -->
                <Button x:Name="CloseButton"
                        Grid.Column="4"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="CloseButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" Text="&#xE711;"/>
                        <TextBlock FontSize="16" VerticalAlignment="Center" Text="Закрыть"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
