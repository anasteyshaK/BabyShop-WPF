<Window x:Class="BabyShop.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Width="1480"
        Height="940"
        MinWidth="1200"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <Border Style="{StaticResource HeroCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="DashboardTitleTextBlock"
                                   FontSize="28"
                                   FontWeight="Black"
                                   Text="Dashboard"/>
                        <TextBlock x:Name="DashboardSubtitleTextBlock"
                                   Margin="0,8,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="Sales, orders, status, and revenue dynamics in one screen."/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Button x:Name="ApplyFiltersButton"
                                MinWidth="150"
                                Margin="0,0,10,0"
                                Click="ApplyFiltersButton_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="Apply filters"/>
                        <Button x:Name="ResetFiltersButton"
                                MinWidth="130"
                                Click="ResetFiltersButton_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Reset"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Margin="0,10,0,0" Padding="10,8" Style="{StaticResource TablePanelStyle}">
                <DockPanel LastChildFill="True">
                    <TextBlock x:Name="FiltersHeaderTextBlock"
                               DockPanel.Dock="Left"
                               Width="78"
                               Margin="0,15,12,0"
                               VerticalAlignment="Top"
                               FontSize="15"
                               FontWeight="Bold"
                               Text="Filters"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="128"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="116"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="128"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="124"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="112"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="112"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="ClientFilterLabelTextBlock" Margin="0,0,0,2" FontSize="11" FontWeight="SemiBold" Text="Client"/>
                            <ComboBox x:Name="ClientComboBox" Height="30" Padding="8,4" DisplayMemberPath="Label" SelectedValuePath="Value"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="StatusFilterLabelTextBlock" Margin="0,0,0,2" FontSize="11" FontWeight="SemiBold" Text="Status"/>
                            <ComboBox x:Name="StatusComboBox" Height="30" Padding="8,4" DisplayMemberPath="Label" SelectedValuePath="Value"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock x:Name="ProductFilterLabelTextBlock" Margin="0,0,0,2" FontSize="11" FontWeight="SemiBold" Text="Product"/>
                            <ComboBox x:Name="ProductComboBox" Height="30" Padding="8,4" DisplayMemberPath="Label" SelectedValuePath="Value"/>
                        </StackPanel>

                        <StackPanel Grid.Column="6">
                            <TextBlock x:Name="FabricFilterLabelTextBlock" Margin="0,0,0,2" FontSize="11" FontWeight="SemiBold" Text="Fabric type"/>
                            <ComboBox x:Name="FabricTypeComboBox" Height="30" Padding="8,4" DisplayMemberPath="Label" SelectedValuePath="Value"/>
                        </StackPanel>

                        <StackPanel Grid.Column="8">
                            <TextBlock x:Name="DateFromLabelTextBlock" Margin="0,0,0,2" FontSize="11" FontWeight="SemiBold" Text="From date"/>
                            <DatePicker x:Name="DateFromPicker" Height="30" Padding="6,3"/>
                        </StackPanel>

                        <StackPanel Grid.Column="10">
                            <TextBlock x:Name="DateToLabelTextBlock" Margin="0,0,0,2" FontSize="11" FontWeight="SemiBold" Text="To date"/>
                            <DatePicker x:Name="DateToPicker" Height="30" Padding="6,3"/>
                        </StackPanel>

                        <StackPanel Grid.Column="12" MinWidth="420">
                            <TextBlock x:Name="AmountRangeLabelTextBlock"
                                       Margin="0,0,0,2"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Text="Amount range"/>
                            <TextBlock x:Name="MinPriceLabelTextBlock"
                                       Visibility="Collapsed"
                                       Text="Minimum amount"/>
                            <TextBlock x:Name="MaxPriceLabelTextBlock"
                                       Visibility="Collapsed"
                                       Text="Maximum amount"/>

                            <Grid Height="30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="MinPriceTextBox"
                                         Height="30"
                                         Padding="8,4"
                                         ToolTip="{Binding Text, ElementName=MinPriceLabelTextBlock}"
                                         TextChanged="AmountTextBox_TextChanged"/>

                                <TextBox x:Name="MaxPriceTextBox"
                                         Grid.Column="2"
                                         Height="30"
                                         Padding="8,4"
                                         ToolTip="{Binding Text, ElementName=MaxPriceLabelTextBlock}"
                                         TextChanged="AmountTextBox_TextChanged"/>

                                <Canvas x:Name="AmountRangeCanvas"
                                        Grid.Column="4"
                                        Height="30"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="AmountRangeCanvas_MouseLeftButtonDown"
                                        MouseMove="AmountRangeCanvas_MouseMove"
                                        MouseLeftButtonUp="AmountRangeCanvas_MouseLeftButtonUp"
                                        SizeChanged="AmountRangeCanvas_SizeChanged">
                                    <Border x:Name="AmountTrackBorder"
                                            Canvas.Top="15"
                                            Height="6"
                                            CornerRadius="3"
                                            Background="{StaticResource AccentSoftBrush}"/>
                                    <Border x:Name="AmountSelectedRangeBorder"
                                            Canvas.Top="15"
                                            Height="6"
                                            CornerRadius="3"
                                            Background="{StaticResource SuccessBrush}"/>
                                    <Ellipse x:Name="MinAmountThumb"
                                             Canvas.Top="8"
                                             Width="20"
                                             Height="20"
                                             Fill="White"
                                             Stroke="{StaticResource SuccessBrush}"
                                             StrokeThickness="3"
                                             Cursor="Hand"
                                             MouseLeftButtonDown="AmountThumb_MouseLeftButtonDown"/>
                                    <Ellipse x:Name="MaxAmountThumb"
                                             Canvas.Top="8"
                                             Width="20"
                                             Height="20"
                                             Fill="White"
                                             Stroke="{StaticResource AccentBrush}"
                                             StrokeThickness="3"
                                             Cursor="Hand"
                                             MouseLeftButtonDown="AmountThumb_MouseLeftButtonDown"/>
                                </Canvas>
                            </Grid>

                            <Grid Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="MinAmountSliderValueTextBlock"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Visibility="Collapsed"
                                           Text="0.00"/>
                                <TextBlock x:Name="MaxAmountSliderValueTextBlock"
                                           Grid.Column="1"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Right"
                                           Visibility="Collapsed"
                                           Text="0.00"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </Border>

            <UniformGrid Margin="0,18,0,0" Columns="4">
                <Border Margin="0,0,12,0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock x:Name="TotalRevenueLabelTextBlock" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" Text="Total revenue"/>
                        <TextBlock x:Name="TotalRevenueValueTextBlock" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Text="0.00"/>
                    </StackPanel>
                </Border>

                <Border Margin="0,0,12,0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock x:Name="OrdersCountLabelTextBlock" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" Text="Orders count"/>
                        <TextBlock x:Name="OrdersCountValueTextBlock" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Text="0"/>
                    </StackPanel>
                </Border>

                <Border Margin="0,0,12,0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock x:Name="AverageCheckLabelTextBlock" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" Text="Average value"/>
                        <TextBlock x:Name="AverageCheckValueTextBlock" Margin="0,10,0,0" FontSize="28" FontWeight="Black" Text="0.00"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock x:Name="RangeLabelTextBlock" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" Text="Min / max"/>
                        <TextBlock x:Name="RangeValueTextBlock" Margin="0,10,0,0" FontSize="20" FontWeight="Black" Text="0.00 - 0.00"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Grid.Column="0"
                        Margin="0,0,16,16"
                        MinHeight="260"
                        Style="{StaticResource TablePanelStyle}">
                    <DockPanel>
                        <TextBlock x:Name="DataGridHeaderTextBlock"
                                   DockPanel.Dock="Top"
                                   Margin="0,0,0,12"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Text="Filtered records"/>
                        <DataGrid x:Name="DashboardDataGrid"
                                  Height="210"
                                  AutoGeneratingColumn="DashboardDataGrid_AutoGeneratingColumn"/>
                    </DockPanel>
                </Border>

                <Border x:Name="StatusChartContainer"
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="0,0,0,16"
                        MinHeight="286"
                        Style="{StaticResource TablePanelStyle}">
                    <DockPanel>
                        <TextBlock x:Name="StatusChartHeaderTextBlock"
                                   DockPanel.Dock="Top"
                                   Margin="0,0,0,12"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Text="Status distribution"/>
                        <Grid Height="236">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Viewbox Width="220"
                                     Height="220"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Top"
                                     Margin="0,4,0,0">
                                <Canvas x:Name="StatusPieCanvas"
                                        Width="220"
                                        Height="220"/>
                            </Viewbox>
                            <ScrollViewer Grid.Column="1"
                                          Margin="18,0,0,0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="StatusLegendPanel" VerticalAlignment="Center"/>
                            </ScrollViewer>
                        </Grid>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,0,16,0"
                        MinHeight="340"
                        Style="{StaticResource TablePanelStyle}">
                    <DockPanel>
                        <TextBlock x:Name="TimelineChartHeaderTextBlock"
                                   DockPanel.Dock="Top"
                                   Margin="0,0,0,12"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Text="Revenue timeline"/>
                        <Border Background="#FFF9FAF9"
                                CornerRadius="8"
                                Padding="10">
                            <Canvas x:Name="TimelineChartCanvas"
                                    Height="260"
                                    ClipToBounds="True"/>
                        </Border>
                    </DockPanel>
                </Border>

                <Grid x:Name="RightChartsGrid"
                      Grid.Row="1"
                      Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="0,0,0,16"
                            MinHeight="160"
                            Style="{StaticResource TablePanelStyle}">
                        <DockPanel>
                            <TextBlock x:Name="ProductChartHeaderTextBlock"
                                       DockPanel.Dock="Top"
                                       Margin="0,0,0,12"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Text="Categories by revenue"/>
                            <ScrollViewer Height="95"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="ProductChartPanel"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1"
                            MinHeight="300"
                            Style="{StaticResource TablePanelStyle}">
                        <DockPanel>
                            <TextBlock x:Name="MonthChartHeaderTextBlock"
                                       DockPanel.Dock="Top"
                                       Margin="0,0,0,12"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Text="Monthly comparison"/>
                            <ScrollViewer Height="230"
                                          VerticalScrollBarVisibility="Disabled"
                                          HorizontalScrollBarVisibility="Auto">
                                <Border Background="#FFF9FAF9"
                                        CornerRadius="8"
                                        Padding="10">
                                    <Canvas x:Name="MonthHistogramCanvas"
                                            MinWidth="420"
                                            Height="210"
                                            ClipToBounds="True"/>
                                </Border>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <TextBlock x:Name="DashboardStatusTextBlock"
                       Margin="4,14,4,0"
                       FontSize="12"
                       Foreground="{StaticResource MutedTextBrush}"
                       Text=""/>
        </StackPanel>
    </ScrollViewer>
</Window>
