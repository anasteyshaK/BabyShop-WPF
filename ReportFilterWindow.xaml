<Window x:Class="BabyShop.ReportFilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reports"
        Width="760"
        Height="620"
        MinWidth="720"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Margin="28,24,28,0"
                Style="{StaticResource HeroCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Border Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,5"
                            HorizontalAlignment="Left">
                        <TextBlock x:Name="ReportModeTagTextBlock"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentDeepBrush}"/>
                    </Border>

                    <TextBlock x:Name="HeaderTitleTextBlock"
                               Margin="0,16,0,0"
                               FontSize="32"
                               FontWeight="Black"
                               Foreground="{StaticResource TextBrush}"/>

                    <TextBlock x:Name="HeaderSubtitleTextBlock"
                               Margin="0,10,0,0"
                               Width="420"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Width="82"
                        Height="82"
                        Margin="22,0,0,0"
                        Background="{StaticResource AccentSoftBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        VerticalAlignment="Top">
                    <Path x:Name="HeaderIconPath"
                          Width="34"
                          Height="34"
                          Stretch="Uniform"
                          Stroke="{StaticResource AccentDeepBrush}"
                          StrokeThickness="1.9"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Data="M4,15 L4,7 M9,15 L9,3 M14,15 L14,10 M3,15 L15,15"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="28,18,28,0"
                Style="{StaticResource CardBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel x:Name="TableSelectionPanel">
                        <TextBlock x:Name="SourceTableLabelTextBlock"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <ComboBox x:Name="SourceTableComboBox"
                                  Margin="0,8,0,0"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Value"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <Grid x:Name="DashboardFilterPanel"
                          Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,14,14,0">
                            <TextBlock x:Name="ClientFilterLabelTextBlock"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <ComboBox x:Name="ClientComboBox"
                                      Margin="0,8,0,0"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="0,14,14,0">
                            <TextBlock x:Name="StatusFilterLabelTextBlock"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <ComboBox x:Name="StatusComboBox"
                                      Margin="0,8,0,0"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Margin="0,14,0,0">
                            <TextBlock x:Name="ProductFilterLabelTextBlock"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <ComboBox x:Name="ProductComboBox"
                                      Margin="0,8,0,0"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Margin="0,14,14,0">
                            <TextBlock x:Name="FabricFilterLabelTextBlock"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <ComboBox x:Name="FabricTypeComboBox"
                                      Margin="0,8,0,0"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,14,14,0">
                            <TextBlock x:Name="DateFromLabelTextBlock"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <DatePicker x:Name="DateFromPicker"
                                        Margin="0,8,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,14,0,0">
                            <TextBlock x:Name="DateToLabelTextBlock"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <DatePicker x:Name="DateToPicker"
                                        Margin="0,8,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Margin="0,14,14,0">
                            <TextBlock x:Name="MinAmountLabelTextBlock"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBox x:Name="MinAmountTextBox"
                                     Margin="0,8,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="0,14,14,0">
                            <TextBlock x:Name="MaxAmountLabelTextBlock"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBox x:Name="MaxAmountTextBox"
                                     Margin="0,8,0,0"/>
                        </StackPanel>

                        <Border Grid.Row="2"
                                Grid.Column="2"
                                Margin="0,14,0,0"
                                Padding="16"
                                Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <TextBlock x:Name="FilterHintTextBlock"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </Border>
                    </Grid>

                    <Grid x:Name="AuditFilterPanel"
                          Margin="0,6,0,0"
                          Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,14,14,0">
                            <TextBlock x:Name="AuditDateFromLabelTextBlock"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <DatePicker x:Name="AuditDateFromPicker"
                                        Margin="0,8,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="0,14,0,0">
                            <TextBlock x:Name="AuditDateToLabelTextBlock"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <DatePicker x:Name="AuditDateToPicker"
                                        Margin="0,8,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Margin="0,14,14,0">
                            <TextBlock x:Name="AuditUserLabelTextBlock"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <ComboBox x:Name="AuditUserComboBox"
                                      Margin="0,8,0,0"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,14,0,0">
                            <TextBlock x:Name="AuditActionLabelTextBlock"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <ComboBox x:Name="AuditActionComboBox"
                                      Margin="0,8,0,0"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,18,0,0"
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2"
              Margin="28,18,28,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="FooterHelpTextBlock"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{StaticResource MutedTextBrush}"/>

            <Grid Grid.Column="1">
                <Grid x:Name="GenerateActionsPanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="CancelButton"
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="132"
                            Content="Cancel"
                            Click="CancelButton_Click"/>

                    <Button x:Name="GenerateButton"
                            Grid.Column="1"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="168"
                            Content="Generate"
                            Click="GenerateButton_Click"/>
                </Grid>

                <WrapPanel x:Name="ReportActionsPanel"
                           Visibility="Collapsed"
                           Orientation="Horizontal">
                    <Button x:Name="PrintButton"
                            Margin="0,0,12,0"
                            MinWidth="132"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Print"
                            Click="PrintButton_Click"/>
                    <Button x:Name="ExportPdfButton"
                            Margin="0,0,12,0"
                            MinWidth="168"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Export PDF"
                            Click="ExportPdfButton_Click"/>
                    <Button x:Name="OpenBrowserButton"
                            Margin="0,0,12,0"
                            MinWidth="196"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Open in browser"
                            Click="OpenBrowserButton_Click"/>
                    <Button x:Name="CloseButton"
                            MinWidth="132"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Cancel"
                            Click="CancelButton_Click"/>
                </WrapPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
