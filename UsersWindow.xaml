<Window x:Class="BabyShop.UsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Users"
        Width="980"
        Height="640"
        MinWidth="860"
        MinHeight="520"
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterOwner"
        Background="#FFFCFAF9">
    <Window.Resources>
        <SolidColorBrush x:Key="UsersBorderBrush" Color="#FFF0E7EA"/>
        <SolidColorBrush x:Key="UsersAccentBrush" Color="#FFEF6F9A"/>
        <SolidColorBrush x:Key="UsersMutedBrush" Color="#FF7B808A"/>
        <SolidColorBrush x:Key="UsersTextBrush" Color="#FF343A45"/>

        <Style x:Key="UsersButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource UsersBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource UsersTextBrush}"/>
        </Style>

        <Style x:Key="UsersPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource UsersButtonStyle}">
            <Setter Property="Background" Value="#FFFFEFF5"/>
            <Setter Property="BorderBrush" Value="#FFFFD6E5"/>
            <Setter Property="Foreground" Value="{StaticResource UsersAccentBrush}"/>
        </Style>

        <Style x:Key="UsersDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource UsersButtonStyle}">
            <Setter Property="Background" Value="#FFFFF6F8"/>
            <Setter Property="BorderBrush" Value="#FFFFD9E5"/>
            <Setter Property="Foreground" Value="#FFD85886"/>
        </Style>

        <Style x:Key="UsersGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FFF4EEF0"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FFFFFCFD"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource UsersTextBrush}"/>
            <Setter Property="RowHeight" Value="46"/>
            <Setter Property="ColumnHeaderHeight" Value="44"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ColumnWidth" Value="*"/>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock x:Name="WindowTitleTextBlock"
                           FontSize="28"
                           FontWeight="Black"
                           Foreground="{StaticResource UsersTextBrush}"
                           Text="Пользователи"/>
                <TextBlock x:Name="WindowSubtitleTextBlock"
                           Margin="0,6,0,0"
                           FontSize="13.5"
                           Foreground="{StaticResource UsersMutedBrush}"
                           Text="В таблице показываются только логин, дата создания и последний вход."/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Top">
                <Button x:Name="AddButton"
                        Margin="0,0,8,0"
                        Style="{StaticResource UsersPrimaryButtonStyle}"
                        Click="AddButton_Click"
                        Content="Добавить"/>
                <Button x:Name="EditButton"
                        Margin="0,0,8,0"
                        Style="{StaticResource UsersButtonStyle}"
                        Click="EditButton_Click"
                        Content="Изменить"/>
                <Button x:Name="DeleteButton"
                        Margin="0,0,8,0"
                        Style="{StaticResource UsersDangerButtonStyle}"
                        Click="DeleteButton_Click"
                        Content="Удалить"/>
                <Button x:Name="RefreshButton"
                        Margin="0,0,8,0"
                        Style="{StaticResource UsersButtonStyle}"
                        Click="RefreshButton_Click"
                        Visibility="Collapsed"
                        Content="Обновить"/>
                <Button x:Name="CloseButton"
                        Style="{StaticResource UsersPrimaryButtonStyle}"
                        Click="CloseButton_Click"
                        Visibility="Collapsed"
                        Content="Закрыть"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,22,0,0"
                Background="White"
                BorderBrush="{StaticResource UsersBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <DataGrid x:Name="UsersDataGrid"
                      Style="{StaticResource UsersGridStyle}"
                      AutoGeneratingColumn="UsersDataGrid_AutoGeneratingColumn"
                      SelectionChanged="UsersDataGrid_SelectionChanged"/>
        </Border>

        <DockPanel Grid.Row="2"
                   Margin="0,16,0,0">
            <TextBlock x:Name="StatusTextBlock"
                       FontSize="12.5"
                       Foreground="{StaticResource UsersMutedBrush}"
                       DockPanel.Dock="Left"
                       Text=""/>
            <TextBlock x:Name="RecordsCountTextBlock"
                       FontSize="12.5"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource UsersTextBrush}"
                       HorizontalAlignment="Right"
                       Text=""/>
        </DockPanel>
    </Grid>
</Window>
