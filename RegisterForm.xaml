<Window x:Class="BabyShop.RegisterForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Baby Shop"
        Width="980"
        Height="840"
        MinWidth="900"
        MinHeight="780"
        FontFamily="{StaticResource RoundedAppFont}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Input field style: TextBox -->
        <Style x:Key="RegisterFieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="{StaticResource RoundedAppFont}"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E8E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CaretBrush" Value="#D96B8A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Height="52"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Icon -->
                                <Viewbox Grid.Column="0" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path x:Name="IconPath"
                                              Fill="#D96B8A"
                                              Data="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                                    </Canvas>
                                </Viewbox>
                                <!-- Placeholder + content -->
                                <Grid Grid.Column="1" Margin="0,0,14,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="PlaceholderText"
                                               Foreground="#BBBBBB"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"
                                               Text="{TemplateBinding Tag}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D96B8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Email TextBox style (envelope icon) -->
        <Style x:Key="EmailTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource RegisterFieldTextBoxStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Height="52"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Viewbox Grid.Column="0" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#D96B8A"
                                              Data="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                                    </Canvas>
                                </Viewbox>
                                <Grid Grid.Column="1" Margin="0,0,14,0" VerticalAlignment="Center">
                                    <TextBlock Foreground="#BBBBBB" VerticalAlignment="Center" IsHitTestVisible="False" Text="{TemplateBinding Tag}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D96B8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PasswordBox style (lock icon) -->
        <Style x:Key="RegisterFieldPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="{StaticResource RoundedAppFont}"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E8E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CaretBrush" Value="#D96B8A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Root"
                                Height="52"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Lock icon -->
                                <Viewbox Grid.Column="0" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#D96B8A"
                                              Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
                                    </Canvas>
                                </Viewbox>
                                <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D96B8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RegisterRevealPasswordTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="{StaticResource RoundedAppFont}"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E8E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CaretBrush" Value="#D96B8A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Height="52"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Viewbox Grid.Column="0" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#D96B8A"
                                              Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
                                    </Canvas>
                                </Viewbox>
                                <Grid Grid.Column="1" Margin="0,0,14,0" VerticalAlignment="Center">
                                    <TextBlock Foreground="#BBBBBB" VerticalAlignment="Center" IsHitTestVisible="False" Text="{TemplateBinding Tag}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D96B8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RegisterEyeToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent">
                            <Grid Width="20" Height="20" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="EyeScaleTransform" ScaleX="1" ScaleY="1"/>
                                </Grid.RenderTransform>
                                <Path x:Name="EyeOutlinePath"
                                      Stroke="#FF9C9CA6"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M2,10 C4.6,5.9 8,4 10,4 C12,4 15.4,5.9 18,10 C15.4,14.1 12,16 10,16 C8,16 4.6,14.1 2,10 Z"/>
                                <Ellipse x:Name="EyePupil"
                                         Width="4.2"
                                         Height="4.2"
                                         Fill="#FF9C9CA6"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Opacity="0"/>
                                <Path x:Name="EyeSlashPath"
                                      Stroke="#FFEF6F9A"
                                      StrokeThickness="1.7"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M4,16 L16,4"
                                      Opacity="1"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="EyeOutlinePath" Property="Stroke" Value="#FFEF6F9A"/>
                                <Setter TargetName="EyePupil" Property="Fill" Value="#FFEF6F9A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="EyePupil"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.14"/>
                                            <DoubleAnimation Storyboard.TargetName="EyeSlashPath"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="EyeScaleTransform"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1"
                                                             Duration="0:0:0.14"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="EyePupil"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.14"/>
                                            <DoubleAnimation Storyboard.TargetName="EyeSlashPath"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetName="EyeScaleTransform"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.88"
                                                             Duration="0:0:0.14"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary button (Create account) -->
        <Style x:Key="CreateAccountButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource RoundedAppFont}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="54"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="#D96B8A"
                                CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{TemplateBinding Content}"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <!-- User+ icon -->
                                <Border Grid.Column="1"
                                        Width="46"
                                        Height="38"
                                        Margin="0,0,8,0"
                                        Background="#C45A78"
                                        CornerRadius="10">
                                    <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="White"
                                                  Data="M15 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm-9-2V7H4v3H1v2h3v3h2v-3h3v-2H6zm9 4c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#C45A78"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#B04E6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button (Sign in) -->
        <Style x:Key="SignInButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="{StaticResource RoundedAppFont}"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="White"
                                BorderBrush="#E8E0E0"
                                BorderThickness="1.5"
                                CornerRadius="14">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Already have an account? "
                                           Foreground="#555555"
                                           FontSize="14"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Sign in"
                                           Foreground="#D96B8A"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFF5F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Root: background image -->
    <Grid>
        <!-- Background image (Image 2) -->
        <Image Source="/Assets/bg_baby.png"
               Stretch="UniformToFill"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

        <!-- Centered white card -->
        <Border Width="460"
                Margin="20"
                Padding="36,26,36,20"
                Background="White"
                CornerRadius="24"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#C0A0A0" Opacity="0.18" BlurRadius="40" ShadowDepth="8" Direction="270"/>
            </Border.Effect>

                <StackPanel>
                    <!-- Header -->
                    <TextBlock Text="CREATE ACCOUNT"
                               FontSize="12"
                               FontWeight="Bold"
                               FontFamily="{StaticResource RoundedAppFont}"
                               Foreground="#D96B8A"
                               
                               Margin="0,0,0,6"/>

                    <TextBlock Text="Join Baby Shop"
                               FontSize="30"
                               FontWeight="Black"
                               FontFamily="{StaticResource RoundedAppFont}"
                               Foreground="#1A1A2E"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Create your account to shop our catalog, track orders, and enjoy a better experience."
                               FontSize="13"
                               FontFamily="{StaticResource RoundedAppFont}"
                               Foreground="#888888"
                               TextWrapping="Wrap"
                               Margin="0,0,0,18"/>

                    <!-- Username -->
                    <TextBlock Text="Username"
                               FontSize="13"
                               FontWeight="SemiBold"
                               FontFamily="{StaticResource RoundedAppFont}"
                               Foreground="#1A1A2E"
                               Margin="0,0,0,7"/>
                    <TextBox x:Name="UsernameTextBox"
                             MaxLength="50"
                             Tag="Choose a username"
                             Style="{StaticResource RegisterFieldTextBoxStyle}"
                             Margin="0,0,0,12"/>

                    <!-- Email -->
                    <TextBlock Text="Email"
                               FontSize="13"
                               FontWeight="SemiBold"
                               FontFamily="{StaticResource RoundedAppFont}"
                               Foreground="#1A1A2E"
                               Margin="0,0,0,7"/>
                    <TextBox x:Name="EmailTextBox"
                             MaxLength="120"
                             Tag="Enter your email"
                             Style="{StaticResource EmailTextBoxStyle}"
                             Margin="0,0,0,12"/>

                    <!-- Password -->
                    <TextBlock Text="Password"
                               FontSize="13"
                               FontWeight="SemiBold"
                               FontFamily="{StaticResource RoundedAppFont}"
                               Foreground="#1A1A2E"
                               Margin="0,0,0,7"/>
                    <Grid Margin="0,0,0,12">
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource RegisterFieldPasswordBoxStyle}"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>
                        <TextBox x:Name="PasswordTextBox"
                                 Visibility="Collapsed"
                                 Style="{StaticResource RegisterRevealPasswordTextBoxStyle}"
                                 Tag="Enter your password"
                                 TextChanged="PasswordTextBox_TextChanged"/>
                        <ToggleButton x:Name="PasswordRevealToggleButton"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      Style="{StaticResource RegisterEyeToggleStyle}"
                                      Checked="PasswordRevealToggleButton_Changed"
                                      Unchecked="PasswordRevealToggleButton_Changed"/>
                    </Grid>

                    <!-- Confirm password -->
                    <TextBlock Text="Confirm password"
                               FontSize="13"
                               FontWeight="SemiBold"
                               FontFamily="{StaticResource RoundedAppFont}"
                               Foreground="#1A1A2E"
                               Margin="0,0,0,7"/>
                    <Grid Margin="0,0,0,12">
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     Style="{StaticResource RegisterFieldPasswordBoxStyle}"
                                     PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                        <TextBox x:Name="ConfirmPasswordTextBox"
                                 Visibility="Collapsed"
                                 Style="{StaticResource RegisterRevealPasswordTextBoxStyle}"
                                 Tag="Repeat your password"
                                 TextChanged="ConfirmPasswordTextBox_TextChanged"/>
                        <ToggleButton x:Name="ConfirmPasswordRevealToggleButton"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      Style="{StaticResource RegisterEyeToggleStyle}"
                                      Checked="ConfirmPasswordRevealToggleButton_Changed"
                                      Unchecked="ConfirmPasswordRevealToggleButton_Changed"/>
                    </Grid>

                    <ComboBox x:Name="RoleComboBox"
                              Visibility="Collapsed"/>

                    <!-- Status text -->
                    <TextBlock x:Name="RegisterStatusTextBlock"
                               Foreground="#D96B8A"
                               FontFamily="{StaticResource RoundedAppFont}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4"/>

                    <!-- Create account button -->
                    <Button x:Name="RegisterButton"
                            Content="Create account"
                            IsDefault="True"
                            Style="{StaticResource CreateAccountButtonStyle}"
                            Click="RegisterButton_Click"
                            Margin="0,0,0,10"/>

                    <!-- Separator -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Height="1" Background="#EEEEEE" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="or" Foreground="#BBBBBB" FontSize="12" Margin="12,0" VerticalAlignment="Center"/>
                        <Border Grid.Column="2" Height="1" Background="#EEEEEE" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Sign in button -->
                    <Button Style="{StaticResource SignInButtonStyle}"
                            IsCancel="True"
                            Click="CancelButton_Click"
                            Margin="0,0,0,10"/>

                    <!-- Security note -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- Shield icon -->
                        <Viewbox Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Fill="#D96B8A"
                                      Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Your data is safe with us. We never share your information."
                                   FontSize="11"
                                   FontFamily="{StaticResource RoundedAppFont}"
                                   Foreground="#AAAAAA"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
        </Border>
    </Grid>
</Window>
