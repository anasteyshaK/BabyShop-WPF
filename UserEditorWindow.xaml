<Window x:Class="BabyShop.UserEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Editor"
        Width="560"
        Height="560"
        MinWidth="520"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#FFFCFAF9">
    <Window.Resources>
        <SolidColorBrush x:Key="EditorBorderBrush" Color="#FFF0E7EA"/>
        <SolidColorBrush x:Key="EditorAccentBrush" Color="#FFEF6F9A"/>
        <SolidColorBrush x:Key="EditorMutedBrush" Color="#FF7B808A"/>
        <SolidColorBrush x:Key="EditorTextBrush" Color="#FF343A45"/>
        <SolidColorBrush x:Key="EditorCardBrush" Color="White"/>

        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource EditorBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource EditorTextBrush}"/>
        </Style>

        <Style x:Key="EditorPasswordStyle" TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource EditorBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource EditorTextBrush}"/>
        </Style>

        <Style x:Key="EditorComboStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource EditorBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource EditorTextBrush}"/>
        </Style>

        <Style x:Key="EditorButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource EditorBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource EditorTextBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="EditorPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource EditorButtonStyle}">
            <Setter Property="Background" Value="#FFFFEFF5"/>
            <Setter Property="BorderBrush" Value="#FFFFD6E5"/>
            <Setter Property="Foreground" Value="{StaticResource EditorAccentBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="TitleTextBlock"
                       FontSize="26"
                       FontWeight="Black"
                       Foreground="{StaticResource EditorTextBrush}"
                       Text="Пользователь"/>
            <TextBlock x:Name="SubtitleTextBlock"
                       Margin="0,6,0,0"
                       FontSize="13"
                       Foreground="{StaticResource EditorMutedBrush}"
                       Text="Заполните данные учетной записи."/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,22,0,0"
                Padding="22"
                Background="{StaticResource EditorCardBrush}"
                BorderBrush="{StaticResource EditorBorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="UsernameLabelTextBlock"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource EditorTextBrush}"
                               Text="Логин"/>
                    <TextBox x:Name="UsernameTextBox"
                             Margin="0,8,0,0"
                             Style="{StaticResource EditorTextBoxStyle}"/>

                    <TextBlock x:Name="RoleLabelTextBlock"
                               Margin="0,18,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource EditorTextBrush}"
                               Text="Роль"/>
                    <ComboBox x:Name="RoleComboBox"
                              Margin="0,8,0,0"
                              Style="{StaticResource EditorComboStyle}"
                              DisplayMemberPath="LocalizedRoleDescription"
                              SelectedValuePath="RoleName"/>
                    <TextBlock x:Name="RoleHintTextBlock"
                               Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="{StaticResource EditorMutedBrush}"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Text="Выберите роль для пользователя."/>

                    <TextBlock x:Name="PasswordLabelTextBlock"
                               Margin="0,18,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource EditorTextBrush}"
                               Text="Пароль"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Margin="0,8,0,0"
                                 Style="{StaticResource EditorPasswordStyle}"/>
                    <TextBlock x:Name="PasswordHintTextBlock"
                               Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="{StaticResource EditorMutedBrush}"
                               TextWrapping="Wrap"
                               Text="Минимум 6 символов."/>

                    <TextBlock x:Name="ConfirmPasswordLabelTextBlock"
                               Margin="0,18,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource EditorTextBrush}"
                               Text="Подтверждение пароля"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Margin="0,8,0,0"
                                 Style="{StaticResource EditorPasswordStyle}"/>

                    <CheckBox x:Name="IsActiveCheckBox"
                              Margin="0,22,0,0"
                              VerticalAlignment="Center"
                              FontSize="13"
                              FontWeight="SemiBold"
                              Foreground="{StaticResource EditorTextBrush}"
                              Content="Активный пользователь"/>

                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,18,0,0"
                               FontSize="12.5"
                               Foreground="{StaticResource EditorAccentBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Margin="0,18,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    MinWidth="132"
                    Height="44"
                    Margin="0,0,8,0"
                    Style="{StaticResource EditorButtonStyle}"
                    Click="CancelButton_Click"
                    Content="Отмена"/>
            <Button x:Name="SaveButton"
                    MinWidth="156"
                    Height="44"
                    Style="{StaticResource EditorPrimaryButtonStyle}"
                    Click="SaveButton_Click"
                    Content="Сохранить"/>
        </StackPanel>
    </Grid>
</Window>
