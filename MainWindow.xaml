<Window x:Class="BabyShop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Baby Shop"
        Width="1440"
        Height="900"
        MinWidth="1180"
        MinHeight="720"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="AdminBgBrush" Color="#FFFCFAF9"/>
        <SolidColorBrush x:Key="SideBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#FFF0E7EA"/>
        <SolidColorBrush x:Key="AccentLightBrush" Color="#FFFFEFF5"/>
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#FFEF6F9A"/>
        <SolidColorBrush x:Key="SageBrush" Color="#FFEAF7F1"/>
        <SolidColorBrush x:Key="SkyBrush" Color="#FFEAF5FF"/>
        <SolidColorBrush x:Key="SunBrush" Color="#FFFFF4D8"/>
        <SolidColorBrush x:Key="PeachBrush" Color="#FFFFEFE7"/>
        <SolidColorBrush x:Key="TextDarkBrush" Color="#FF343A45"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#FF7B808A"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#FF44B486"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFFF8E55"/>
        <FontFamily x:Key="AppFont">Nunito, Quicksand, Poppins, Trebuchet MS, Segoe UI Variable, Segoe UI</FontFamily>

        <Style x:Key="SidebarNavStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="#F7FFFFFF"/>
            <Setter Property="BorderBrush" Value="#F0E3EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="Padding" Value="18,15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14"
                                                  ShadowDepth="0"
                                                  Opacity="0.08"
                                                  Color="#FFD38DA6"/>
                            </Border.Effect>
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFFFFFF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#F2C7D8"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentStrongBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFCECF3"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#F4C5D7"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentStrongBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="AdminGridCellStyle" TargetType="DataGridCell">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextBlock.TextAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="AdminGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextBlock.TextAlignment" Value="Left"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
        </Style>

        <Style x:Key="AdminGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="True"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FFF4EEF0"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FFFFFCFD"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="13.2"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="RowHeight" Value="48"/>
            <Setter Property="ColumnHeaderHeight" Value="46"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CellStyle" Value="{StaticResource AdminGridCellStyle}"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource AdminGridHeaderStyle}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ColumnWidth" Value="*"/>
        </Style>

        <Style x:Key="TopActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="SoftActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="AccentSoftButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="58"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentDeepBrush}"/>
                                <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.76"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AdminBgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="292"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SideBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Margin="28,0,24,20"
                            Panel.ZIndex="2"
                            HorizontalAlignment="Stretch">
                    <Image Source="/Assets/babyshop-logo.png"
                           Width="288"
                           Margin="0,-18,0,0"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality" Height="270" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="BrandTitleTextBlock"
                               Visibility="Collapsed"
                               Text="Baby Shop"/>
                    <TextBlock x:Name="BrandSubtitleTextBlock"
                               Visibility="Collapsed"
                               Text="soft care, clear orders"/>
                    <Border Visibility="Collapsed"
                            Margin="0,12,0,0"
                            Padding="12,10"
                            Background="#FFF4FBF7"
                            BorderBrush="#FFE3EFE8"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusDot"
                                         Width="10"
                                         Height="10"
                                         Fill="{StaticResource SuccessBrush}"
                                         VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusTextBlock"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextDarkBrush}"
                                           Text="Connected to MySQL"/>
                            </StackPanel>
                            <TextBlock x:Name="LastRefreshTextBlock"
                                       Margin="18,6,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="Last refresh:"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="2" Margin="24,24,24,0" Visibility="Collapsed">
                    <TextBlock x:Name="ReportsPopupTitleTextBlock" Text="Reports"/>
                    <TextBlock x:Name="AllRecordsReportButtonTitleTextBlock" Text="All records list"/>
                    <TextBlock x:Name="AllRecordsReportButtonNoteTextBlock" Text="Full export for the selected table."/>
                    <TextBlock x:Name="FilteredReportButtonTitleTextBlock" Text="Filtered report"/>
                    <TextBlock x:Name="FilteredReportButtonNoteTextBlock" Text="Records by period, client, status, and amount."/>
                    <TextBlock x:Name="AnalyticsReportButtonTitleTextBlock" Text="Analytics report"/>
                    <TextBlock x:Name="AnalyticsReportButtonNoteTextBlock" Text="Summary and analytics for orders, statuses, and revenue."/>
                    <TextBlock x:Name="AuditReportButtonTitleTextBlock" Text="Audit log"/>
                    <TextBlock x:Name="AuditReportButtonNoteTextBlock" Text="User actions, logins, registration and data changes."/>
                    <TextBlock x:Name="LanguageLabelTextBlock" Text="Language"/>
                </Grid>

                <Grid Grid.Row="0" Grid.RowSpan="4" Margin="18,0,18,18" ClipToBounds="False" Panel.ZIndex="0">
                    <Border CornerRadius="28"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            ClipToBounds="True" Margin="-46,0,-24,-31">
                        <Grid>
                            <Image Source="/Assets/admin-sidebar-bg-v2.png"
                                   Stretch="UniformToFill"
                                   Opacity="0.98" Margin="-63,-26,-47,0" Height="977" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <StackPanel Margin="18,260,18,0"
                                VerticalAlignment="Top">
                        <RadioButton x:Name="NavCustomers" Style="{StaticResource SidebarNavStyle}" IsChecked="True" Click="NavButton_Click" Tag="0">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="18" Height="18" Margin="0,0,16,0" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M9,9 A3,3 0 1 1 9,3 A3,3 0 1 1 9,9 M3,17 C4,13 14,13 15,17"/>
                                <TextBlock x:Name="NavCustomersTextBlock" Text="Clients"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavFabrics" Style="{StaticResource SidebarNavStyle}" Click="NavButton_Click" Tag="1">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="18" Height="18" Margin="0,0,16,0" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M4,5 L16,5 L16,15 L4,15 Z M6,3 L14,3 M7,8 L13,8"/>
                                <TextBlock x:Name="NavFabricsTextBlock" Text="Fabrics"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavProducts" Style="{StaticResource SidebarNavStyle}" Click="NavButton_Click" Tag="2">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="18" Height="18" Margin="0,0,16,0" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M4,7 L10,3 L16,7 L10,11 Z M4,7 L4,13 L10,17 L16,13 L16,7"/>
                                <TextBlock x:Name="NavProductsTextBlock" Text="Products"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavOrders" Style="{StaticResource SidebarNavStyle}" Click="NavButton_Click" Tag="3">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="18" Height="18" Margin="0,0,16,0" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M5,6 L15,6 L16,17 L4,17 Z M7,6 C7,2 13,2 13,6"/>
                                <TextBlock x:Name="NavOrdersTextBlock" Text="Orders"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavOrderItems" Style="{StaticResource SidebarNavStyle}" Click="NavButton_Click" Tag="4">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="18" Height="18" Margin="0,0,16,0" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M4,5 L16,5 L16,17 L4,17 Z M7,9 L13,9 M7,13 L13,13 M7,2 L13,2 L13,5 L7,5 Z"/>
                                <TextBlock x:Name="NavOrderItemsTextBlock" Text="Order Items"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="88"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1" Margin="10,0,0,0">
                <Grid Margin="38,0,28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="510"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="510"
                            Height="46"
                            Padding="14,0"
                            Background="White"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            VerticalAlignment="Center">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="26"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SearchPlaceholderTextBlock"
                                       Text="Search clients, orders, products..."
                                       FontSize="13"
                                       Margin="2,0,0,0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                            <TextBox x:Name="SearchBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="13"
                                     Foreground="{StaticResource TextDarkBrush}"
                                     CaretBrush="{StaticResource TextDarkBrush}"
                                     Padding="0"
                                     Margin="2,0,8,0"
                                     VerticalContentAlignment="Center"
                                     HorizontalContentAlignment="Left"
                                     Panel.ZIndex="1"
                                     VerticalAlignment="Center"
                                     Tag="Search clients, orders, products..."
                                     TextChanged="SearchBox_TextChanged"/>
                            <Path Grid.Column="1"
                                  Width="17"
                                  Height="17"
                                  Stretch="Uniform"
                                  Stroke="{StaticResource TextMutedBrush}"
                                  StrokeThickness="1.7"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M8,14 A6,6 0 1 1 8,2 A6,6 0 1 1 8,14 M13,13 L17,17"
                                  VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2"
                          Margin="0,0,16,0"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="ReportsButton"
                                    Style="{StaticResource AccentSoftButtonStyle}"
                                    Width="58"
                                    Height="58"
                                    Margin="0,0,8,0"
                                    Click="ReportsButton_Click">
                                <Path Width="24"
                                      Height="24"
                                      Stretch="Uniform"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M3,5 L17,5 M6,10 L14,10 M4,15 L16,15 M7,3 L7,7 M13,8 L13,12 M10,13 L10,17"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Button>

                            <Button x:Name="BackupButton"
                                    Style="{StaticResource AccentSoftButtonStyle}"
                                    Width="58"
                                    Height="58"
                                    Margin="0,0,8,0"
                                    Click="BackupButton_Click">
                                <Path Width="24"
                                      Height="24"
                                      Stretch="Uniform"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M9,3 L9,13 M5,9 L9,13 L13,9 M4,15 L14,15"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Button>

                            <Button x:Name="DashboardButton"
                                    Style="{StaticResource AccentSoftButtonStyle}"
                                    Width="58"
                                    Height="58"
                                    Click="DashboardButton_Click">
                                <Path Width="24"
                                      Height="24"
                                      Stretch="Uniform"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M3,15 L3,9 M8,15 L8,5 M13,15 L13,11 M2,15 L16,15 M3,9 L6,7 L9,9 L13,4"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>

                        <Popup x:Name="ReportsPopup"
                               PlacementTarget="{Binding ElementName=ReportsButton}"
                               Placement="Bottom"
                               HorizontalOffset="-122"
                               VerticalOffset="12"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               StaysOpen="False">
                            <Border Width="292"
                                    Padding="16"
                                    Background="White"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock FontSize="15"
                                               FontWeight="Black"
                                               Foreground="{StaticResource TextDarkBrush}"
                                               Text="{Binding Text, ElementName=ReportsPopupTitleTextBlock}"/>

                                    <Button x:Name="AllRecordsReportButton"
                                            Margin="0,14,0,0"
                                            Padding="14"
                                            HorizontalContentAlignment="Stretch"
                                            Background="#FFFFF8FB"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            Click="OpenAllRecordsReportButton_Click">
                                        <StackPanel>
                                            <TextBlock FontSize="13.2"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextDarkBrush}"
                                                       Text="{Binding Text, ElementName=AllRecordsReportButtonTitleTextBlock}"/>
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Text, ElementName=AllRecordsReportButtonNoteTextBlock}"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="FilteredReportButton"
                                            Margin="0,10,0,0"
                                            Padding="14"
                                            HorizontalContentAlignment="Stretch"
                                            Background="#FFF7FCFB"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            Click="OpenFilteredReportButton_Click">
                                        <StackPanel>
                                            <TextBlock FontSize="13.2"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextDarkBrush}"
                                                       Text="{Binding Text, ElementName=FilteredReportButtonTitleTextBlock}"/>
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Text, ElementName=FilteredReportButtonNoteTextBlock}"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="AnalyticsReportButton"
                                            Margin="0,10,0,0"
                                            Padding="14"
                                            HorizontalContentAlignment="Stretch"
                                            Background="#FFFFFBF4"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            Click="OpenAnalyticsReportButton_Click">
                                        <StackPanel>
                                            <TextBlock FontSize="13.2"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextDarkBrush}"
                                                       Text="{Binding Text, ElementName=AnalyticsReportButtonTitleTextBlock}"/>
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Text, ElementName=AnalyticsReportButtonNoteTextBlock}"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="AuditReportButton"
                                            Margin="0,10,0,0"
                                            Padding="14"
                                            HorizontalContentAlignment="Stretch"
                                            Background="#FFF6F8FF"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            Click="OpenAuditReportButton_Click">
                                        <StackPanel>
                                            <TextBlock FontSize="13.2"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextDarkBrush}"
                                                       Text="{Binding Text, ElementName=AuditReportButtonTitleTextBlock}"/>
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Text, ElementName=AuditReportButtonNoteTextBlock}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <Border Grid.Column="3"
                            Margin="0,0,16,0"
                            Background="White"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            VerticalAlignment="Center">
                        <Button x:Name="CurrentUserMenuButton"
                                Padding="12,10"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="CurrentUserMenuButton_Click" Height="58">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="46"
                                        Height="46"
                                        CornerRadius="12"
                                        Background="{StaticResource AccentLightBrush}" Margin="0,-4,0,-4">
                                    <TextBlock x:Name="CurrentUserInitialsTextBlock"
                                               Text="AD"
                                               Foreground="{StaticResource AccentStrongBrush}"
                                               FontSize="13"
                                               FontWeight="Black"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,2,0,0">
                                    <TextBlock x:Name="CurrentUsernameTextBlock"
                                               Text="Admin"
                                               FontWeight="Black"
                                               Foreground="{StaticResource TextDarkBrush}"/>
                                    <TextBlock x:Name="CurrentRoleTextBlock"
                                               Text="Administrator"
                                               FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                </StackPanel>
                                <Path x:Name="CurrentUserChevronPath"
                                      Grid.Column="2"
                                      Width="10"
                                      Height="6"
                                      Margin="16,0,2,0"
                                      VerticalAlignment="Center"
                                      Stroke="{StaticResource TextMutedBrush}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M1,1 L5,5 L9,1"/>
                            </Grid>
                        </Button>
                    </Border>

                    <Popup x:Name="CurrentUserPopup"
                           PlacementTarget="{Binding ElementName=CurrentUserMenuButton}"
                           Placement="Bottom"
                           HorizontalOffset="0"
                           VerticalOffset="12"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           StaysOpen="False">
                        <Border Width="260"
                                Padding="16"
                                Background="White"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <Button x:Name="ManageUsersMenuButton"
                                        Padding="14"
                                        HorizontalContentAlignment="Stretch"
                                        Background="#FFFFF8FB"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Click="ManageUsersMenuButton_Click">
                                    <StackPanel>
                                        <TextBlock x:Name="ManageUsersMenuTitleTextBlock"
                                                   FontSize="13.2"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextDarkBrush}"
                                                   Text="Users"/>
                                        <TextBlock x:Name="ManageUsersMenuNoteTextBlock"
                                                   Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="Open the users table from the database view."/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <Border Grid.Column="4"
                            Width="58"
                            Height="58"
                            Background="White"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            VerticalAlignment="Center">
                        <Button x:Name="LanguageToggleButton"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="LanguageToggleButton_Click" Height="58">
                            <Grid Margin="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border x:Name="LanguageToggleThumb"
                                        Grid.Row="0"
                                        Margin="0"
                                        Background="{StaticResource AccentLightBrush}"
                                        CornerRadius="10"/>
                                <TextBlock x:Name="LanguageRuTextBlock"
                                           Grid.Row="0"
                                           Text="RU"
                                           FontSize="11"
                                           FontWeight="Black"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentStrongBrush}"/>
                                <TextBlock x:Name="LanguageEnTextBlock"
                                           Grid.Row="1"
                                           Text="EN"
                                           FontSize="11"
                                           FontWeight="Black"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                            </Grid>
                        </Button>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="38,26,28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="PageTitleTextBlock"
                               FontSize="28"
                               FontWeight="Black"
                               Foreground="{StaticResource TextDarkBrush}"
                               Text="Clients"/>
                    <TextBlock x:Name="PageSubtitleTextBlock"
                               Margin="0,6,0,0"
                               FontSize="13.5"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="All registered clients and their contact information"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button x:Name="RefreshButton"
                            Margin="0,0,8,0"
                            Style="{StaticResource SoftActionButtonStyle}"
                            Click="RefreshButton_Click">
                        <TextBlock x:Name="RefreshButtonTextBlock" Text="Refresh" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="DeleteButton"
                            Margin="0,0,8,0"
                            Style="{StaticResource SoftActionButtonStyle}"
                            Click="DeleteButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Width="15" Height="15" Margin="0,0,7,0"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Data="M3,4 L15,4 M7,4 L7,2 L11,2 L11,4 M5,4 L5,15 L13,15 L13,4 M7,8 L7,12 M11,8 L11,12"/>
                            <TextBlock x:Name="DeleteButtonTextBlock" Text="Delete" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="EditButton"
                            Margin="0,0,8,0"
                            Style="{StaticResource SoftActionButtonStyle}"
                            Click="EditButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Width="15" Height="15" Margin="0,0,7,0"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Data="M3,12.5 L12.5,3 A2,2 0 0 1 15,5.5 L5.5,15 L3,15 Z M10.5,5 L13,7.5"/>
                            <TextBlock x:Name="EditButtonTextBlock" Text="Edit" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AddButton"
                            Style="{StaticResource TopActionButtonStyle}"
                            Click="AddButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Width="15" Height="15" Margin="0,0,7,0"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M9,3 L9,15 M3,9 L15,9"/>
                            <TextBlock x:Name="AddButtonTextBlock" Text="Add Client" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2"
                        Visibility="Collapsed">
                <TextBlock x:Name="CustomerStatLabelTextBlock" Text="Clients"/>
                <TextBlock x:Name="CustomerCountTextBlock" Text="-"/>
                <TextBlock x:Name="FabricStatLabelTextBlock" Text="Fabrics"/>
                <TextBlock x:Name="FabricCountTextBlock" Text="-"/>
                <TextBlock x:Name="ProductStatLabelTextBlock" Text="Products"/>
                <TextBlock x:Name="ProductCountTextBlock" Text="-"/>
                <TextBlock x:Name="OrderStatLabelTextBlock" Text="Orders"/>
                <TextBlock x:Name="OrderCountTextBlock" Text="-"/>
                <TextBlock x:Name="OrderItemStatLabelTextBlock" Text="Order Items"/>
                <TextBlock x:Name="OrderProductCountTextBlock" Text="-"/>
            </StackPanel>

            <Border x:Name="OrderStatusFilterPanel"
                    Grid.Row="3"
                    Margin="38,18,28,0"
                    Padding="16,10"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    VerticalAlignment="Top"
                    Visibility="Collapsed">
                <DockPanel LastChildFill="False">
                    <TextBlock x:Name="OrderStatusFilterLabelTextBlock"
                               DockPanel.Dock="Left"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="Order Status"/>
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <CheckBox x:Name="OrderStatusPendingCheckBox" Margin="0,0,14,0" VerticalAlignment="Center" IsChecked="True" Checked="OrderStatusFilter_Changed" Unchecked="OrderStatusFilter_Changed" Content="Pending"/>
                        <CheckBox x:Name="OrderStatusShippedCheckBox" Margin="0,0,14,0" VerticalAlignment="Center" IsChecked="True" Checked="OrderStatusFilter_Changed" Unchecked="OrderStatusFilter_Changed" Content="Shipped"/>
                        <CheckBox x:Name="OrderStatusCompletedCheckBox" VerticalAlignment="Center" IsChecked="True" Checked="OrderStatusFilter_Changed" Unchecked="OrderStatusFilter_Changed" Content="Completed"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="3"
                    x:Name="RecordsPanel"
                    Margin="38,18,28,28"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <DataGrid x:Name="CustomerGrid" Style="{StaticResource AdminGridStyle}" Visibility="Visible"/>
                        <DataGrid x:Name="FabricGrid" Style="{StaticResource AdminGridStyle}" Visibility="Collapsed"/>
                        <DataGrid x:Name="ProductGrid" Style="{StaticResource AdminGridStyle}" Visibility="Collapsed"/>
                        <DataGrid x:Name="CustomerOrderGrid" Style="{StaticResource AdminGridStyle}" Visibility="Collapsed"/>
                        <DataGrid x:Name="OrderProductGrid" Style="{StaticResource AdminGridStyle}" Visibility="Collapsed"/>
                    </Grid>
                    <Border Grid.Row="1" Padding="18,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <TextBlock x:Name="FooterMessageTextBlock" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Text="Showing records"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
