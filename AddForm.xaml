<Window x:Class="BabyShop.AddForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Add record"
        Width="640"
        Height="760"
        MinWidth="600"
        MinHeight="680"
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Canvas Grid.RowSpan="3"
                IsHitTestVisible="False"
                ClipToBounds="True">
            <Ellipse Width="180" Height="180" Canvas.Left="360" Canvas.Top="-70" Fill="{StaticResource AccentSoftBrush}" Opacity="0.58"/>
            <Ellipse Width="120" Height="120" Canvas.Left="-58" Canvas.Top="520" Fill="{StaticResource MintSoftBrush}" Opacity="0.62"/>
            <Rectangle Width="42" Height="42" Canvas.Left="470" Canvas.Top="624" RadiusX="8" RadiusY="8" Fill="{StaticResource SunSoftBrush}" Opacity="0.72"/>
        </Canvas>

        <Border Grid.Row="0" Style="{StaticResource HeroCardStyle}">
            <StackPanel>
                <TextBlock x:Name="TitleTextBlock" FontSize="30" FontWeight="Black" Text="Add record" />
                <TextBlock x:Name="SubtitleTextBlock"
                           Margin="0,8,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="Fill in the fields below to add a new row." />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,22,0,0" Style="{StaticResource CardBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="FieldsPanel" />
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <TextBlock x:Name="HelpTextBlock"
                       Visibility="Collapsed"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap"
                       Text="" />

            <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        MinWidth="146"
                        Height="46"
                        Margin="0,0,12,0"
                        Padding="18,8"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="CancelButton_Click"
                        Content="Cancel" />
                <Button x:Name="SubmitButton"
                        MinWidth="174"
                        Height="46"
                        Padding="18,8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="AddButton_Click"
                        Content="Add" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
