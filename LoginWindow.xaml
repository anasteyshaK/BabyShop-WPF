<Window x:Class="BabyShop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BabyShop"
        Title="Baby Shop"
        Width="1050"
        Height="670"
        MinWidth="1050"
        MinHeight="670"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <SolidColorBrush x:Key="LoginPinkBrush" Color="#FFEF6F9A"/>
        <SolidColorBrush x:Key="LoginPinkSoftBrush" Color="#FFFFEEF4"/>
        <SolidColorBrush x:Key="LoginInkBrush" Color="#FF2F3542"/>
        <SolidColorBrush x:Key="LoginMutedBrush" Color="#FF7C7E86"/>
        <SolidColorBrush x:Key="LoginLineBrush" Color="#FFF1D9E2"/>

        <DropShadowEffect x:Key="LoginCardShadow"
                          BlurRadius="22"
                          ShadowDepth="0"
                          Opacity="0.08"
                          Color="#FFD7A9B6"/>

        <Style x:Key="LoginFieldBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource LoginInkBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"/>
                            <TextBlock x:Name="Watermark"
                                       Text="{TemplateBinding Tag}"
                                       Foreground="#FF9B9CA3"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Watermark" Property="Opacity" Value="0.62"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource LoginInkBrush}"/>
            <Setter Property="BorderBrush" Value="#FFECECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource LoginPinkSoftBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource LoginLineBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="8"
            ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="528"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" ClipToBounds="True">
                <Image Source="/Assets/login-babyshop-bg-v2.png"
                       Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <Grid Margin="58,56,42,0"
                      VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Image Source="/Assets/babyshop-logo.png"
                           Width="433"
                           Stretch="Uniform"
                           HorizontalAlignment="Left"
                           RenderOptions.BitmapScalingMode="HighQuality" Margin="-21,-71,0,119" Grid.RowSpan="2"/>

                    <TextBlock Grid.Row="1"
                               Margin="1034,291,-1034,-195"
                               FontSize="29"
                               LineHeight="38"
                               FontWeight="Black"
                               Foreground="{StaticResource LoginInkBrush}"
                               TextWrapping="Wrap"
                               Text="Orders and products&#x0a;in one place" Grid.RowSpan="2"/>

                    <TextBlock Grid.Row="1"
                               Margin="0,85,0,115"
                               Width="310"
                               HorizontalAlignment="Center"
                               FontSize="15"
                               LineHeight="24"
                               Foreground="{StaticResource LoginMutedBrush}"
                               TextWrapping="Wrap"
                               Text=""
                               />
                </Grid>

                <local:HeartsOverlay/>
            </Grid>

            <Grid Grid.Column="1"
                  Background="White"
                  Margin="0">
                <StackPanel Width="404"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="ACCOUNT ACCESS"
                               FontSize="11"
                               FontWeight="Black"
                               Foreground="{StaticResource LoginPinkBrush}"/>

                    <TextBlock Margin="0,16,0,0"
                               Text="Welcome back"
                               FontSize="31"
                               FontWeight="Black"
                               Foreground="{StaticResource LoginInkBrush}"/>

                    <TextBlock Margin="0,12,0,0"
                               Width="318"
                               HorizontalAlignment="Left"
                               Text="Sign in to continue."
                               TextWrapping="Wrap"
                               FontSize="15"
                               LineHeight="23"
                               Foreground="{StaticResource LoginMutedBrush}"/>

                    <TextBlock Margin="0,30,0,8"
                               Text="Login"
                               FontSize="14"
                               Foreground="{StaticResource LoginInkBrush}"/>

                    <Border Height="59"
                            Padding="18,0"
                            Background="White"
                            BorderBrush="{StaticResource LoginLineBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Path Width="18"
                                  Height="18"
                                  Stretch="Uniform"
                                  Stroke="{StaticResource LoginPinkBrush}"
                                  StrokeThickness="1.7"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M2,5 L9,10 L16,5 M2,5 L2,15 L16,15 L16,5 Z"
                                  VerticalAlignment="Center"/>

                            <TextBox x:Name="LoginUsernameTextBox"
                                     Grid.Column="1"
                                     Tag="Enter your login"
                                     Style="{StaticResource LoginFieldBoxStyle}"
                                     Margin="20,0,0,0"/>
                        </Grid>
                    </Border>

                    <TextBlock Margin="0,30,0,8"
                               Text="Password"
                               FontSize="14"
                               Foreground="{StaticResource LoginInkBrush}"/>

                    <Border Height="54"
                            Padding="18,0"
                            Background="White"
                            BorderBrush="#FFECECEF"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Path Width="18"
                                  Height="18"
                                  Stretch="Uniform"
                                  Stroke="{StaticResource LoginPinkBrush}"
                                  StrokeThickness="1.7"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M4,8 L4,16 L16,16 L16,8 Z M7,8 L7,5 C7,2 13,2 13,5 L13,8"
                                  VerticalAlignment="Center"/>

                            <Grid Grid.Column="1" Margin="20,0,0,0">
                                <PasswordBox x:Name="LoginPasswordBox"
                                             PasswordChanged="LoginPasswordBox_PasswordChanged"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Padding="0"
                                             VerticalContentAlignment="Center"
                                             FontSize="14"
                                             Foreground="{StaticResource LoginInkBrush}"/>
                                <TextBox x:Name="LoginPasswordTextBox"
                                         Visibility="Collapsed"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="0"
                                         VerticalContentAlignment="Center"
                                         FontSize="14"
                                         Foreground="{StaticResource LoginInkBrush}"
                                         TextChanged="LoginPasswordTextBox_TextChanged"/>
                                <TextBlock x:Name="PasswordPlaceholderTextBlock"
                                           Text="Enter your password"
                                           Foreground="#FF9B9CA3"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="ShowPasswordCheckBox"
                                  Grid.Column="0"
                                  Content="Show password"
                                  FontSize="14"
                                  Foreground="{StaticResource LoginInkBrush}"
                                  Checked="ShowPasswordCheckBox_Changed"
                                  Unchecked="ShowPasswordCheckBox_Changed"/>
                    </Grid>

                    <Button Margin="0,34,0,0"
                            Height="53"
                            Background="{StaticResource LoginPinkBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="LoginButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Root"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Root" Property="Opacity" Value="0.78"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Grid Width="356">
                            <TextBlock Text="Sign in"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <Path Width="14"
                                  Height="14"
                                  HorizontalAlignment="Right"
                                  Margin="0,0,22,0"
                                  Stretch="Uniform"
                                  Stroke="White"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M4,2 L10,8 L4,14"
                                  VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <TextBlock x:Name="LoginStatusTextBlock"
                               Margin="0,12,0,0"
                               Foreground="{StaticResource LoginPinkBrush}"
                               TextWrapping="Wrap"/>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Height="1"
                                Background="#FFF0F0F2"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Margin="16,0"
                                   Text="or"
                                   Foreground="{StaticResource LoginMutedBrush}"
                                   FontSize="13"/>
                        <Border Grid.Column="2"
                                Height="1"
                                Background="#FFF0F0F2"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Style="{StaticResource LoginSecondaryButtonStyle}"
                                Click="OpenRegisterWindow_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="18"
                                      Height="18"
                                      Margin="0,0,12,0"
                                      Stretch="Uniform"
                                      Stroke="{StaticResource LoginPinkBrush}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M9,9 A3,3 0 1 1 9,3 A3,3 0 1 1 9,9 M3,17 C4,13 14,13 15,17"
                                      VerticalAlignment="Center"/>
                                <TextBlock Text="Create account"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2"
                                Style="{StaticResource LoginSecondaryButtonStyle}"
                                Click="OpenStorefrontPreview_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="18"
                                      Height="18"
                                      Margin="0,0,12,0"
                                      Stretch="Uniform"
                                      Stroke="{StaticResource LoginPinkBrush}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M4,7 L4,17 L16,17 L16,7 Z M6,7 C6,3 14,3 14,7"
                                      VerticalAlignment="Center"/>
                                <TextBlock Text="Preview shop"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
